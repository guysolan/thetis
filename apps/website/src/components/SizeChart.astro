---
const sizes = {
  EU: 42,
  UK: 8,
  "US Men": 9,
  "US Women": 10.5,
};
---

<div class="mx-auto max-w-md overflow-x-auto">
  <table class="w-full text-sm text-left border-collapse">
    <thead>
      <tr class="bg-primary/10 border-primary border-b-2">
        <th class="px-4 py-3 font-semibold">Location</th>
        <th class="px-4 py-3 font-semibold">Small</th>
        <th class="px-4 py-3 font-semibold">Large</th>
      </tr>
    </thead>
    <tbody>
      {
        Object.entries(sizes).map(([location, threshold]) => (
          <tr class="border-neutral-200 dark:border-neutral-700 border-b">
            <td class="px-4 py-3 font-medium text-neutral-900 dark:text-neutral-100">
              {location}
            </td>
            <td class="px-4 py-3 text-neutral-700 dark:text-neutral-300">
              &lt; {threshold}
            </td>
            <td class="px-4 py-3 text-neutral-700 dark:text-neutral-300">
              &ge; {threshold}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
