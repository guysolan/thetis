---
import type { ConditionId } from "@/content/conditions/registry";
import { getConditionById } from "@/content/conditions/registry";
import type { Lang } from "@/config/languages";
import { getLearnHubHeroCopy } from "@/content/learn-hub-hero";
import ConditionHubSelect from "@/components/condition/ConditionHubSelect.astro";
import { Activity, CheckCircle, Footprints, Stethoscope } from "lucide-react";
import { Image } from "astro:assets";
import AchillesRuptureDrawing from "@/assets/drawings/achilles-drawing.svg";
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";
import { conditionHubChooseConditionLabel } from "@/content/condition-hub-select-labels";
import CourseBuyButton from "@/components/CourseBuyButton";
import { SHOPIFY_COURSE_PRODUCTS } from "@/lib/shopify-course-price";
import { getLocalizedShopHubHref } from "@/lib/condition-nav";

interface Props {
    conditionId: ConditionId;
    lang: Lang;
}

const { conditionId, lang } = Astro.props;
const c = getConditionById(conditionId);
const hubHero = getLearnHubHeroCopy(conditionId, lang);

const learnHeroCommerce: Record<
    Lang,
    { addCourseToCart: string; buyKit: (conditionLabel: string) => string }
> = {
    en: {
        addCourseToCart: "Add course to cart",
        buyKit: (name) => `Buy ${name} Kit`,
    },
    de: {
        addCourseToCart: "Kurs in den Warenkorb",
        buyKit: (name) => `${name} Kit kaufen`,
    },
    fr: {
        addCourseToCart: "Ajouter le cours au panier",
        buyKit: (name) => `Acheter le kit ${name}`,
    },
    es: {
        addCourseToCart: "Añadir curso al carrito",
        buyKit: (name) => `Comprar kit ${name}`,
    },
    it: {
        addCourseToCart: "Aggiungi corso al carrello",
        buyKit: (name) => `Compra kit ${name}`,
    },
};
const commerce = learnHeroCommerce[lang];
const shopHref = getLocalizedShopHubHref(lang, conditionId);
const chooseConditionLabel = conditionHubChooseConditionLabel[lang];
---

<section class="pb-16 md:pb-24 color-gradient">
    <div class="mx-auto px-4 max-w-7xl">
        <div class="flex lg:flex-row flex-col items-center gap-12">
            <div class="flex-1 lg:text-left text-center">
                <div
                    class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-2 rounded-full"
                >
                    {
                        hubHero.icon === "footprints" ? (
                            <Footprints className="w-4 h-4 text-primary" />
                        ) : hubHero.icon === "activity" ? (
                            <Activity className="w-4 h-4 text-primary" />
                        ) : (
                            <Stethoscope className="w-4 h-4 text-primary" />
                        )
                    }
                    <span
                        class="font-medium text-primary text-sm uppercase tracking-wider"
                    >
                        {hubHero.kicker}
                    </span>
                </div>
                <ConditionHubSelect
                    lang={lang}
                    hub="learn"
                    conditionId={conditionId}
                    label={chooseConditionLabel}
                    selectId="learn-condition-select"
                />
                <h1
                    class="mb-6 font-bold text-neutral-900 dark:text-neutral-100 text-4xl md:text-5xl lg:text-6xl leading-tight"
                >
                    {c.label}
                    <span class="text-primary">
                        {" "}
                        {hubHero.titleAccent}
                    </span>
                </h1>
                <p
                    class="mx-auto lg:mx-0 mb-8 max-w-2xl text-neutral-600 dark:text-neutral-400 text-lg md:text-xl leading-relaxed"
                >
                    {hubHero.description}
                </p>

                <div
                    class="flex flex-wrap justify-center lg:justify-start gap-4 mb-8"
                >
                    <div
                        class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400"
                    >
                        <CheckCircle className="w-5 h-5 text-primary" />
                        <span>{hubHero.bullets[0]}</span>
                    </div>
                    <div
                        class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400"
                    >
                        <CheckCircle className="w-5 h-5 text-primary" />
                        <span>{hubHero.bullets[1]}</span>
                    </div>
                    <div
                        class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400"
                    >
                        <CheckCircle className="w-5 h-5 text-primary" />
                        <span>{hubHero.bullets[2]}</span>
                    </div>
                </div>

                <div
                    class="flex sm:flex-row flex-col flex-wrap justify-center lg:justify-start gap-3"
                >
                    <CourseBuyButton
                        client:load
                        productId={SHOPIFY_COURSE_PRODUCTS.ESSENTIALS_COURSE}
                        size="lg"
                        className="shadow-lg font-bold text-lg"
                    >
                        {commerce.addCourseToCart}
                    </CourseBuyButton>
                    <a
                        href={shopHref}
                        class={cn(
                            buttonVariants({
                                size: "lg",
                                variant: "outline",
                            }),
                            "font-semibold",
                        )}
                    >
                        {commerce.buyKit(c.label)}
                    </a>
                </div>
            </div>
            <div
                class="flex flex-shrink-0 justify-center items-center w-full lg:w-2/5"
            >
                {
                    conditionId === "achilles-rupture" ? (
                        <Image
                            src={AchillesRuptureDrawing}
                            alt="Achilles tendon illustration"
                            class="w-full max-w-md max-h-[50vh] object-contain"
                            width={400}
                            height={500}
                        />
                    ) : (
                        <div
                            class="flex justify-center items-center bg-primary/5 dark:bg-primary/10 shadow-sm border border-primary/20 dark:border-primary/30 rounded-2xl w-full max-w-md aspect-square"
                            aria-hidden="true"
                        >
                            {hubHero.icon === "footprints" ? (
                                <Footprints className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                            ) : hubHero.icon === "activity" ? (
                                <Activity className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                            ) : (
                                <Stethoscope className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                            )}
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</section>
