---
/**
 * EN-only extras for the Achilles rupture learn hub: cross-links, subscribe,
 * timeline, quick jumps, course CTA (phase URLs stay under /guide/...).
 */
import { conditions } from "@/content/conditions/registry";
import { achillesRuptureGuideHubPhases } from "@/content/guide";
import SubscribeBlock from "@/components/CTA/SubscribeBlock.astro";
import CourseCTA from "@/components/CTA/CourseCTA.astro";
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";
import { BookOpen, ArrowRight, Clock } from "lucide-react";

const guidePhases = achillesRuptureGuideHubPhases;
---

<!-- All conditions -->
<section class="bg-white py-12 border-neutral-200 border-b">
    <div class="mx-auto px-4 max-w-6xl">
        <h2 class="mb-2 font-bold text-neutral-900 text-2xl md:text-3xl text-center">
            Recovery guides by condition
        </h2>
        <p class="mx-auto mb-8 max-w-2xl text-neutral-600 text-lg text-center">
            Choose a condition to open its learn hub.
        </p>
        <ul class="flex sm:flex-row flex-col flex-wrap justify-center gap-4 sm:gap-6">
            {conditions
                .slice()
                .sort((a, b) => a.sortOrder - b.sortOrder)
                .map((c) => (
                    <li class="sm:flex-1 sm:min-w-[200px] sm:max-w-xs">
                        <a
                            href={c.learnPath}
                            class={cn(
                                buttonVariants({ variant: "outline", size: "lg" }),
                                "justify-center w-full font-semibold text-center",
                            )}
                        >
                            {c.label}
                        </a>
                    </li>
                ))}
        </ul>
    </div>
</section>

<section class="bg-neutral-50 py-12">
    <div class="mx-auto px-4 max-w-3xl">
        <SubscribeBlock source="guide_index" lang="en" />
    </div>
</section>

<section id="phases" class="py-16 md:py-24">
    <div class="mx-auto px-4 max-w-6xl">
        <div class="mb-12 text-center">
            <div class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-1.5 rounded-full font-medium text-primary text-sm uppercase tracking-wide">
                <BookOpen className="w-4 h-4" />
                Complete Timeline
            </div>
            <h2 class="mb-4 font-bold text-neutral-900 text-3xl md:text-4xl">
                Your Recovery Journey
            </h2>
            <p class="mx-auto max-w-2xl text-neutral-600 text-lg">
                Click on any phase to read the complete guide for that stage of recovery.
            </p>
        </div>

        <div class="relative">
            <div class="hidden lg:block top-0 bottom-0 left-1/2 absolute bg-gradient-to-b from-red-500 via-yellow-500 to-green-500 rounded-full w-1 -translate-x-1/2 transform" />
            <div class="space-y-8 lg:space-y-12">
                {guidePhases.map((phase, index) => (
                    <div
                        class={cn(
                            "relative lg:flex lg:items-center lg:gap-8",
                            index % 2 === 0 ? "lg:flex-row" : "lg:flex-row-reverse",
                        )}
                    >
                        <div class="hidden left-1/2 absolute lg:flex justify-center items-center -translate-x-1/2 transform">
                            <div class={cn("shadow-md border-4 border-white rounded-full w-6 h-6", phase.color)} />
                        </div>

                        <a
                            href={`/${phase.slug}`}
                            class={cn(
                                "group block bg-white hover:bg-primary/5 shadow-sm hover:shadow-lg p-6 md:p-8 border border-neutral-200 hover:border-primary/50 rounded-2xl transition-all",
                                "lg:w-[calc(50%-2rem)]",
                                index % 2 === 0 ? "lg:mr-auto" : "lg:ml-auto",
                            )}
                        >
                            <div class="flex items-start gap-4">
                                <div
                                    class={cn(
                                        "flex flex-shrink-0 justify-center items-center rounded-xl w-14 h-14 font-bold text-white text-sm",
                                        phase.color,
                                    )}
                                >
                                    <div class="text-center leading-tight">
                                        <div class="opacity-80 text-xs">Week</div>
                                        <div>
                                            {phase.week
                                                .replace(/^Week\s+/i, "")
                                                .replace(/^Weeks\s+/i, "")}
                                        </div>
                                    </div>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <h3 class="mb-2 font-bold text-neutral-900 group-hover:text-primary text-xl md:text-2xl transition-colors">
                                        {phase.title}
                                    </h3>
                                    <p class="mb-4 text-neutral-600">{phase.description}</p>

                                    <div class="flex flex-wrap gap-2 mb-4">
                                        {phase.highlights.map((highlight) => (
                                            <span class="bg-neutral-100 group-hover:bg-primary/10 px-2 py-1 rounded font-medium text-neutral-600 text-xs transition-colors">
                                                {highlight}
                                            </span>
                                        ))}
                                    </div>

                                    <div class="flex items-center gap-2 font-semibold text-primary">
                                        Read Full Guide
                                        <ArrowRight className="w-4 h-4 transition-transform group-hover:translate-x-1" />
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<section class="bg-primary/5 py-16">
    <div class="mx-auto px-4 max-w-4xl text-center">
        <h2 class="mb-4 font-bold text-neutral-900 text-2xl md:text-3xl">
            Not Sure Where to Start?
        </h2>
        <p class="mb-8 text-neutral-600 text-lg">
            Jump to the phase that matches where you are in your recovery journey.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
            <a href="/guide/weeks-0-1" class={cn(buttonVariants({ variant: "default" }), "gap-2")}>
                <Clock className="w-4 h-4" />
                Just Injured
            </a>
            <a href="/guide/weeks-4-6" class={cn(buttonVariants({ variant: "outline" }), "gap-2")}>
                In the Boot
            </a>
            <a href="/guide/weeks-10-12" class={cn(buttonVariants({ variant: "outline" }), "gap-2")}>
                Leaving the Boot
            </a>
            <a href="/guide/weeks-13-25" class={cn(buttonVariants({ variant: "outline" }), "gap-2")}>
                Doing Physio
            </a>
        </div>
    </div>
</section>

<CourseCTA lang="en" variant="full" />
