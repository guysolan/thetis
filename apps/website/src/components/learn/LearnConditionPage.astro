---
import type { ConditionId } from "@/content/conditions/registry";
import { getConditionById } from "@/content/conditions/registry";
import type { Lang } from "@/config/languages";
import { getLearnHubHeroCopy } from "@/content/learn-hub-hero";
import ConditionHubResourceSections from "@/components/condition/ConditionHubResourceSections.astro";
import AchillesRuptureLearnEnExtras from "@/components/learn/AchillesRuptureLearnEnExtras.astro";
import {
    Activity,
    Calendar,
    CheckCircle,
    Footprints,
    Stethoscope,
} from "lucide-react";
import { Image } from "astro:assets";
import AchillesRuptureDrawing from "@/assets/drawings/achilles-drawing.svg";
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";
import { getLocalizedShopHubHref } from "@/lib/condition-nav";
import AchillesSplintLearnBand from "@/components/condition/AchillesSplintLearnBand.astro";

interface Props {
    conditionId: ConditionId;
    lang: Lang;
}

const { conditionId, lang } = Astro.props;
const c = getConditionById(conditionId);
const isAchillesEn = conditionId === "achilles-rupture" && lang === "en";
const hubHero = getLearnHubHeroCopy(conditionId, lang);

const learnIndexByLang: Record<Lang, string> = {
    en: "/learn",
    de: "/de/learn",
    fr: "/fr/learn",
    es: "/es/learn",
    it: "/it/learn",
};
const learnIndexHref = learnIndexByLang[lang];

const backLabelByLang: Record<Lang, string> = {
    en: "← All learn hubs",
    de: "← Alle Lern-Hubs",
    fr: "← Tous les hubs",
    es: "← Todos los hubs",
    it: "← Tutti gli hub",
};
const shopCtaByLang: Record<Lang, string> = {
    en: "Shop this condition",
    de: "Zum Shop",
    fr: "Voir la boutique",
    es: "Ir a la tienda",
    it: "Vai allo shop",
};

const shopHref = getLocalizedShopHubHref(lang, conditionId);
const isAchilles = conditionId === "achilles-rupture";
---

<main class="space-y-0">
    {
        isAchillesEn ? (
            <>
                <section class="color-gradient pb-16 md:pb-24">
                    <div class="mx-auto px-4 max-w-7xl">
                        <div class="flex lg:flex-row flex-col items-center gap-12">
                            <div class="flex-1 lg:text-left text-center">
                                <div class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-2 rounded-full">
                                    <Calendar className="w-4 h-4 text-primary" />
                                    <span class="font-medium text-primary text-sm uppercase tracking-wider">
                                        Recovery Timeline
                                    </span>
                                </div>
                                <h1 class="mb-6 font-bold text-neutral-900 dark:text-neutral-100 text-4xl md:text-5xl lg:text-6xl leading-tight">
                                    Achilles Rupture{" "}
                                    <span class="text-primary">
                                        Recovery Guide
                                    </span>
                                </h1>
                                <p class="mx-auto lg:mx-0 mb-8 max-w-2xl text-neutral-600 dark:text-neutral-400 text-lg md:text-xl leading-relaxed">
                                    Your complete week-by-week guide to
                                    recovery. From the moment of injury to
                                    returning to full activity —
                                    <strong class="text-neutral-900 dark:text-neutral-100">
                                        evidence-based guidance
                                    </strong>{" "}
                                    at every stage.
                                </p>

                                <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-8">
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>7 detailed phases</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>Evidence-based</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>Surgeon reviewed</span>
                                    </div>
                                </div>

                                <div class="flex flex-col sm:flex-row flex-wrap justify-center lg:justify-start gap-3">
                                    <a
                                        href="#phases"
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "default",
                                            }),
                                            "text-lg font-bold shadow-lg",
                                        )}
                                    >
                                        Start Reading →
                                    </a>
                                    <a
                                        href={learnIndexHref}
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "outline",
                                            }),
                                            "font-semibold",
                                        )}
                                    >
                                        {backLabelByLang[lang]}
                                    </a>
                                    <a
                                        href={shopHref}
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "outline",
                                            }),
                                            "font-semibold",
                                        )}
                                    >
                                        {shopCtaByLang[lang]}
                                    </a>
                                </div>
                            </div>
                            <div class="flex-shrink-0 w-full lg:w-2/5">
                                <Image
                                    src={AchillesRuptureDrawing}
                                    alt="Achilles tendon illustration"
                                    class="w-full max-h-[50vh] object-contain"
                                    width={400}
                                    height={500}
                                />
                            </div>
                        </div>
                    </div>
                </section>
                {isAchilles && <AchillesSplintLearnBand {lang} />}
                <ConditionHubResourceSections {conditionId} {lang} />
                <AchillesRuptureLearnEnExtras />
            </>
        ) : (
            <>
                <section class="color-gradient pb-16 md:pb-24">
                    <div class="mx-auto px-4 max-w-7xl">
                        <div class="flex lg:flex-row flex-col items-center gap-12">
                            <div class="flex-1 lg:text-left text-center">
                                <div class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-2 rounded-full">
                                    {hubHero.icon === "footprints" ? (
                                        <Footprints className="w-4 h-4 text-primary" />
                                    ) : hubHero.icon === "activity" ? (
                                        <Activity className="w-4 h-4 text-primary" />
                                    ) : (
                                        <Stethoscope className="w-4 h-4 text-primary" />
                                    )}
                                    <span class="font-medium text-primary text-sm uppercase tracking-wider">
                                        {hubHero.kicker}
                                    </span>
                                </div>
                                <h1 class="mb-6 font-bold text-neutral-900 dark:text-neutral-100 text-4xl md:text-5xl lg:text-6xl leading-tight">
                                    {c.label}
                                    <span class="text-primary">
                                        {" "}
                                        {hubHero.titleAccent}
                                    </span>
                                </h1>
                                <p class="mx-auto lg:mx-0 mb-8 max-w-2xl text-neutral-600 dark:text-neutral-400 text-lg md:text-xl leading-relaxed">
                                    {hubHero.description}
                                </p>

                                <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-8">
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>{hubHero.bullets[0]}</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>{hubHero.bullets[1]}</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
                                        <CheckCircle className="w-5 h-5 text-primary" />
                                        <span>{hubHero.bullets[2]}</span>
                                    </div>
                                </div>

                                <div class="flex flex-col sm:flex-row flex-wrap justify-center lg:justify-start gap-3">
                                    <a
                                        href="#condition-resources-heading"
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "default",
                                            }),
                                            "text-lg font-bold shadow-lg",
                                        )}
                                    >
                                        {hubHero.cta} →
                                    </a>
                                    <a
                                        href={learnIndexHref}
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "outline",
                                            }),
                                            "font-semibold",
                                        )}
                                    >
                                        {backLabelByLang[lang]}
                                    </a>
                                    <a
                                        href={shopHref}
                                        class={cn(
                                            buttonVariants({
                                                size: "lg",
                                                variant: "outline",
                                            }),
                                            "font-semibold",
                                        )}
                                    >
                                        {shopCtaByLang[lang]}
                                    </a>
                                </div>
                            </div>
                            <div class="flex justify-center items-center flex-shrink-0 w-full lg:w-2/5">
                                {conditionId === "achilles-rupture" ? (
                                    <Image
                                        src={AchillesRuptureDrawing}
                                        alt="Achilles tendon illustration"
                                        class="w-full max-h-[50vh] max-w-md object-contain"
                                        width={400}
                                        height={500}
                                    />
                                ) : (
                                    <div
                                        class="flex justify-center items-center bg-primary/5 dark:bg-primary/10 shadow-sm border border-primary/20 dark:border-primary/30 rounded-2xl w-full max-w-md aspect-square"
                                        aria-hidden="true"
                                    >
                                        {hubHero.icon === "footprints" ? (
                                            <Footprints className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                                        ) : hubHero.icon === "activity" ? (
                                            <Activity className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                                        ) : (
                                            <Stethoscope className="w-[min(40vw,11rem)] h-[min(40vw,11rem)] text-primary/75" />
                                        )}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </section>
                {isAchilles && <AchillesSplintLearnBand {lang} />}
                <ConditionHubResourceSections {conditionId} {lang} />
            </>
        )
    }
</main>
