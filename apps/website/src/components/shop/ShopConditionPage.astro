const t = copy[lang];
const courseRoute = getCourseRouteForShopCondition(lang, conditionId);

/** Rich “From Thetis” cards + reviews (Achilles shop only). */
const achillesFromThetisCopy: Record<
  Lang,
  {
    freeShipping: string;
    guarantee30Day: string;
    easyReturns: string;
    instantAccess: string;
    readersLine: string;
    addCourse: string;
    splintImageAlt: string;
    reviewsKicker: string;
    reviewsTitle: string;
    reviewsSubtitle: string;
    reviewsViewAll: string;
  }
> = {
  en: {
    freeShipping: "Free shipping",
    guarantee30Day: "30-day guarantee",
    easyReturns: "Easy returns",
    instantAccess: "Instant access — start today",
    readersLine: "Join 20,000 readers",
    addCourse: "Add course to cart",
    splintImageAlt: "Thetis night splint for Achilles recovery",
    reviewsKicker: "TRUSTED BY THOUSANDS",
    reviewsTitle: "Join 5,000+ Patients Who've Found Relief",
    reviewsSubtitle:
      "Real reviews from real patients recovering from Achilles rupture",
    reviewsViewAll: "View all reviews",
  },
  de: {
    freeShipping: "Kostenloser Versand",
    guarantee30Day: "30-Tage-Garantie",
    easyReturns: "Einfache Rückgabe",
    instantAccess: "Sofortiger Zugang — heute starten",
    readersLine: "Schließen Sie sich 20.000 Lesern an",
    addCourse: "Kurs in den Warenkorb",
    splintImageAlt: "Thetis Nachtschiene für die Achilles-Genesung",
