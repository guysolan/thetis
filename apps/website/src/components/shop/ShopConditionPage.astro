                    {at.addCourse}
                  </CourseBuyButton>
                  <a
                    href={courseRoute.href}
                    class={cn(
                      buttonVariants({ variant: "outline", size: "lg" }),
                      "w-full sm:w-auto font-semibold",
                    )}
                  >
                    {t.viewCourse.replace(/\s*→\s*$/, "")}
                  </a>
                </div>
              </article>
            ) : null}
          </div>
        ) : fromThetisLinks.length === 0 ? (
          <p class="text-neutral-600 dark:text-neutral-400">
            {t.noOurProducts}
          </p>
        ) : (
          <ul class="gap-4 grid sm:grid-cols-2">
            {fromThetisLinks.map((r) => {
              const isCourse =
                courseRoute !== null && r.href === courseRoute.href;
              const showSplintThumb =
                !isCourse &&
                isAchillesShop &&
                (r.href.includes("achilles-rupture-splint") ||
                  r.href.includes("achillessehnenriss-schiene") ||
                  r.href.includes("attelle-rupture") ||
                  r.href.includes("tutore-tendine") ||
                  r.href.includes("bota-ortopedica"));
              const rowLayout =
                isCourse || showSplintThumb
                  ? "sm:flex-row flex-col"
                  : "flex-col";
              return (
                <li>
                  <a
                    href={r.href}
                    class={cn(
                      "flex items-stretch gap-5 bg-primary/5 hover:bg-primary/10 shadow-sm hover:shadow-md p-5 sm:p-6 border border-primary/20 hover:border-primary/40 rounded-xl transition-all",
                      rowLayout,
                    )}
                  >
                    {isCourse ? (
                      <div class="flex justify-center items-center bg-primary/10 border border-primary/15 rounded-xl w-[150px] h-[150px] shrink-0">
                        <BookOpen
                          className="w-14 h-14 text-primary"
                          aria-hidden
                        />
                      </div>
                    ) : showSplintThumb ? (
                      <div class="border border-primary/15 rounded-xl w-[150px] h-[150px] overflow-hidden shrink-0">
                        <img
                          src="/images/night_splint_bed_top_square.jpg"
                          alt=""
                          class="w-full h-full object-cover"
                          width={150}
                          height={150}
                          loading="lazy"
                        />
                      </div>
                    ) : null}
                    <div class="flex flex-col flex-1 min-w-0">
                      <h3 class="mb-2 font-semibold text-primary text-lg leading-snug">
                        {r.title}
                      </h3>
                      <p class="flex-1 text-neutral-600 dark:text-neutral-400 text-sm">
                        {r.description}
                      </p>
                      <span class="inline-block mt-3 font-medium text-primary text-sm">
                        {isCourse ? t.viewCourse : t.viewProduct}
                      </span>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </div>
  </section>

  {
    isAchillesShop ? (
      <section class="bg-gradient-to-b from-white dark:from-neutral-950 via-primary/5 dark:via-primary/10 to-white dark:to-neutral-950 py-12 md:py-16 border-neutral-200 dark:border-neutral-800 border-b">
        <div class="mx-auto px-4 max-w-7xl">
          <div class="mb-8 md:mb-12 text-center">
            <div class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-2 rounded-full">
              <Check className="w-4 md:w-5 h-4 md:h-5 text-primary" />
              <p class="font-medium text-primary text-xs md:text-sm uppercase tracking-widest">
                {at.reviewsKicker}
              </p>
            </div>
            <h2 class="mb-4 font-bold text-neutral-900 dark:text-neutral-100 text-2xl md:text-3xl lg:text-4xl">
              {at.reviewsTitle}
            </h2>
            <p class="mx-auto mb-6 max-w-3xl text-neutral-600 dark:text-neutral-400 text-base md:text-lg">
              {at.reviewsSubtitle}
            </p>
          </div>
          <div class="mb-8">
            <EnhancedReviewCarousel client:load />
          </div>
          {reviewsRoute ? (
            <div class="text-center">
              <a
                href={reviewsRoute.href}
                class="inline-flex items-center gap-2 hover:bg-primary px-6 py-3 border-2 border-primary rounded-lg font-semibold text-primary hover:text-white transition-colors"
              >
                {at.reviewsViewAll}
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </div>
          ) : null}
        </div>
      </section>
    ) : null
  }

  <ShopCatalogueProductGrid
    lang={lang}
    products={shopProducts}
    sectionTitle={t.recommended}
  />
</main>
