---
import type { ConditionId } from "@/content/conditions/registry";
import { getConditionById } from "@/content/conditions/registry";
import type { Lang } from "@/config/languages";
import {
  getCatalogueProductsForCondition,
  orderedShopProductsForDisplay,
} from "@thetis/catalogue";
import { getRouteBySlugAndLanguage } from "@/content/routes";
import { conditionHubChooseConditionLabel } from "@/content/condition-hub-select-labels";
import ConditionHubSelect from "@/components/condition/ConditionHubSelect.astro";
import { getCourseRouteForShopCondition } from "@/lib/condition-nav";
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";
import CourseBuyButton from "@/components/CourseBuyButton.tsx";
import SplintShopBuyButton from "@/components/shop/SplintShopBuyButton.tsx";
import PriceDisplay from "@/components/PriceDisplay.tsx";
import VariantPriceDisplay from "@/components/shop/VariantPriceDisplay.tsx";
import EnhancedReviewCarousel from "@/components/reviews/EnhancedReviewCarousel";
import { NIGHT_SPLINT_VARIANTS } from "@/lib/shopify/variants";
import { COURSE_VARIANTS } from "@/lib/shopify/products";
import { SHOPIFY_COURSE_PRODUCTS } from "@/lib/shopify-course-price";
import ShopCatalogueProductGrid from "@/components/shop/ShopCatalogueProductGrid.astro";
import posterImage from "../../../../../packages/catalogue/assets/poster-image.png";
import achillesCourseImage from "../../../../../packages/catalogue/assets/achilles-rope-ends-pointed-down.png";
import {
  BookOpen,
  Check,
  RotateCcw,
  ShieldCheck,
  ShoppingBag,
  Truck,
} from "lucide-react";

interface Props {
  conditionId: ConditionId;
  lang: Lang;
}

const { conditionId, lang } = Astro.props;
const c = getConditionById(conditionId);

function shopConditionHeroTagline(lang: Lang, conditionLabel: string): string {
  const name = conditionLabel
    .split(/\s+/)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
    .join(" ");
  const byLang: Record<Lang, string> = {
    en: `Shop recovery gear curated by surgeons for ${name}.`,
    de: `Von Chirurgen kuratiertes Recovery-Equipment für ${name}.`,
    fr: `Équipement de récupération sélectionné par des chirurgiens pour ${name}.`,
    es: `Material de recuperación seleccionado por cirujanos para ${name}.`,
    it: `Equipaggiamento per il recupero selezionato dai chirurghi per ${name}.`,
  };
  return byLang[lang];
}

