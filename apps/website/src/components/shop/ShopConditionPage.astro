        {t.ourProducts}
      </h2>
      {
        isAchillesShop ? (
          <div
            class={cn(
              "gap-8 grid",
              courseRoute ? "md:grid-cols-2" : "md:grid-cols-1 max-w-2xl",
            )}
          >
            <article class="flex flex-col bg-neutral-50 dark:bg-neutral-900/50 shadow-sm p-6 md:p-8 border border-neutral-200 dark:border-neutral-700 rounded-2xl">
              <a
                href={learnMoreSplintHref}
                class="block hover:opacity-95 mb-5 border border-primary/20 dark:border-primary/30 rounded-xl w-full max-w-[320px] aspect-square overflow-hidden mr-auto"
              >
                <img
                  src="/images/night_splint_bed_top_square.jpg"
                  alt={at.splintImageAlt}
                  width={680}
                  height={680}
                  class="w-full h-full object-center object-cover"
                  loading="lazy"
                />
              </a>
              <h3 class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl leading-snug">
                {splintRoute?.title ?? "Achilles Night Splint"}
              </h3>
              <p class="mb-4 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                {splintRoute?.description ?? ""}
              </p>
              <PriceDisplay
                client:load
                size="lg"
                showFreeShipping={false}
                className="mb-4"
              />
              <div class="flex flex-wrap gap-2 mb-5">
                <span class="inline-flex items-center gap-1.5 bg-primary/10 px-2.5 py-1 rounded-full font-medium text-neutral-800 dark:text-neutral-200 text-xs leading-none">
                  <Truck className="w-3.5 h-3.5 text-primary" aria-hidden />
                  {at.freeShipping}
                </span>
                <span class="inline-flex items-center gap-1.5 bg-primary/10 px-2.5 py-1 rounded-full font-medium text-neutral-800 dark:text-neutral-200 text-xs leading-none">
                  <ShieldCheck className="w-3.5 h-3.5 text-primary" aria-hidden />
                  {at.guarantee30Day}
                </span>
                <span class="inline-flex items-center gap-1.5 bg-primary/10 px-2.5 py-1 rounded-full font-medium text-neutral-800 dark:text-neutral-200 text-xs leading-none">
                  <RotateCcw className="w-3.5 h-3.5 text-primary" aria-hidden />
                  {at.easyReturns}
                </span>
              </div>
              <div class="flex sm:flex-row flex-col flex-wrap gap-3 mt-auto">
                <SplintShopBuyButton
                  client:load
                  variantId={NIGHT_SPLINT_VARIANTS.largeLeft}
                  size="lg"
                  className="w-full sm:w-auto"
                  addToCartLabel={ah.ctaAddToCart}
                  externalBuyLabel={ah.ctaBuyPartner}
                />
                <a
                  href={learnMoreSplintHref}
                  class={cn(
                    buttonVariants({ variant: "outline", size: "lg" }),
                    "w-full sm:w-auto font-semibold",
                  )}
                >
                  {ah.ctaLearnMore}
                </a>
              </div>
            </article>
            {courseRoute ? (
              <article class="flex flex-col bg-neutral-50 dark:bg-neutral-900/50 shadow-sm p-6 md:p-8 border border-neutral-200 dark:border-neutral-700 rounded-2xl">
                <div class="mb-5 border border-primary/15 rounded-xl w-full max-w-[320px] overflow-hidden mr-auto">
                  <img
                    src={achillesCourseImage.src}
                    alt="Achilles tendon healing position comparison"
                    width={1024}
                    height={1024}
                    class="w-full h-auto object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl leading-snug">
                  {courseRoute.title}
                </h3>
                <p class="mb-4 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                  {courseRoute.description}
                </p>
                <VariantPriceDisplay
                  client:load
                  variantId={COURSE_VARIANTS.ESSENTIALS}
                  size="lg"
                  stripUsPrefix
                  className="mb-2"
                />
                <p class="flex items-center gap-2 mb-4 text-primary text-sm">
                  <Check className="w-4 h-4 shrink-0" aria-hidden />
                  {at.instantAccess}
                </p>
                <p class="mb-6 font-semibold text-neutral-800 dark:text-neutral-200 text-sm">
                  {at.readersLine}
                </p>
                <div class="flex sm:flex-row flex-col flex-wrap gap-3 mt-auto">
                  <CourseBuyButton
                    client:load
                    productId={SHOPIFY_COURSE_PRODUCTS.ESSENTIALS_COURSE}
                    size="lg"
                    className="w-full sm:w-auto"
