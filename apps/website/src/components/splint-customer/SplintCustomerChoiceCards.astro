---
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import type { Lang } from "@/config/languages";
import { getSplintCustomerPath } from "@/lib/splint-customer-paths";
import { getSplintCustomerCopy } from "@/features/splint-customer/splintCustomerCopy";
import LocationPrice from "@/components/splint-customer/LocationPrice";
import SplintCustomerCoursePrice from "@/components/splint-customer/SplintCustomerCoursePrice";
import { BookOpen, Video } from "lucide-react";

interface Props {
  lang?: Lang;
  highlight?: "review" | "course";
  discountCode?: string;
  compact?: boolean;
}

const {
  lang = "en",
  highlight,
  discountCode = "SPLINT20",
  compact = false,
} = Astro.props;

const t = getSplintCustomerCopy(lang).cards;
const reviewHref = getSplintCustomerPath("review", lang);
const courseHref = getSplintCustomerPath("course", lang);

const cardClass = (option: "review" | "course") =>
  cn(
    "flex flex-col bg-white dark:bg-neutral-800 shadow-lg p-6 border-2 rounded-2xl h-full text-left transition-shadow",
    highlight === option
      ? "border-primary shadow-md ring-2 ring-primary/20"
      : "border-neutral-200 dark:border-neutral-700 hover:border-primary/40",
  );
---

<div
  class={cn(
    "gap-5 grid",
    compact
      ? "md:grid-cols-2 max-w-3xl mx-auto"
      : "md:grid-cols-2 max-w-4xl mx-auto",
  )}
>
  <article class={cardClass("review")}>
    <div
      class="flex justify-center items-center bg-primary/10 mb-4 rounded-xl w-12 h-12 text-primary"
    >
      <Video className="w-6 h-6" />
    </div>
    <p class="mb-1 font-medium text-primary text-xs uppercase tracking-widest">
      {t.option1}
    </p>
    <h2 class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl">
      {t.reviewTitle}
    </h2>
    <p
      class="mb-4 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed"
    >
      {t.reviewDescBefore}{" "}
      <LocationPrice gbp={20} eur={20} usd={25} client:load />{" "}
      {t.reviewDescAfter}
    </p>
    {
      highlight !== "review" && (
        <a
          href={reviewHref}
          class={cn(
            buttonVariants({ variant: "default", size: "lg" }),
            "justify-center mt-auto w-full",
          )}
        >
          {t.reviewCta}
        </a>
      )
    }
  </article>

  <article class={cardClass("course")}>
    <div
      class="flex justify-center items-center bg-primary/10 mb-4 rounded-xl w-12 h-12 text-primary"
    >
      <BookOpen className="w-6 h-6" />
    </div>
    <p class="mb-1 font-medium text-primary text-xs uppercase tracking-widest">
      {t.option2}
    </p>
    <h2 class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl">
      {t.courseTitle}
    </h2>
    <p
      class="mb-3 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed"
    >
      {t.courseDescBefore}{" "}
      <span class="font-mono font-semibold text-primary">{discountCode}</span>
      {t.courseDescAfter}
    </p>
    <SplintCustomerCoursePrice className="mb-4" client:load />
    {
      highlight !== "course" && (
        <a
          href={courseHref}
          class={cn(
            buttonVariants({ variant: "default", size: "lg" }),
            "justify-center mt-auto w-full",
          )}
        >
          {t.courseCta}
        </a>
      )
    }
  </article>
</div>

<p class="mt-5 text-neutral-500 dark:text-neutral-400 text-sm text-center">
  {getSplintCustomerCopy(lang).cards.footer}
</p>
