---
import Slide from "@/components/Slide.astro";
import type { TradeDeckPartner } from "@/content/trade/decks";
import { Check } from "lucide-astro";

export interface Props {
  partner: TradeDeckPartner;
}

const { partner } = Astro.props;
const { ecosystem } = partner;
---

<Slide title={ecosystem.title} paragraph={ecosystem.intro}>
  <ul class="gap-6 grid md:grid-cols-3 mx-auto max-w-5xl">
    {
      ecosystem.products.map((product) => (
        <li class="flex flex-col bg-white dark:bg-neutral-900 shadow-sm border border-neutral-200 dark:border-neutral-700 rounded-2xl overflow-hidden">
          <div class="bg-neutral-50 dark:bg-neutral-950 aspect-[4/3]">
            <img
              src={product.imageSrc}
              alt={product.imageAlt}
              width={480}
              height={360}
              class="p-5 w-full h-full object-contain"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col flex-1 p-5">
            <p class="font-medium text-primary text-xs uppercase tracking-wide">
              {product.role}
            </p>
            <h3 class="mt-1 mb-2 font-semibold text-neutral-900 dark:text-neutral-100 text-lg">
              {product.name}
            </h3>
            <p class="flex-1 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
              {product.description}
            </p>
            <p class="mt-4 pt-4 border-neutral-200 dark:border-neutral-700 border-t font-medium text-neutral-500 text-xs">
              {product.brand === "partner" ? partner.name : "Thetis Medical"}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
  <ul class="gap-3 grid mx-auto mt-8 max-w-2xl">
    {
      ecosystem.products.map((product) => (
        <li class="flex gap-2 text-neutral-700 dark:text-neutral-300 text-sm">
          <Check class="mt-0.5 w-4 h-4 text-primary shrink-0" aria-hidden />
          <span>
            <strong>{product.name}</strong> — {product.role.toLowerCase()}
          </span>
        </li>
      ))
    }
  </ul>
</Slide>
