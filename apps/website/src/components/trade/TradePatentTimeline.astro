---
import { tradePatentPortfolio } from "@/content/trade/tradePatentTimeline";

export interface Props {
  portfolioTitle: string;
}

const { portfolioTitle } = Astro.props;
---

<div class="mx-auto w-full max-w-3xl">
  <h3
    class="mb-4 font-semibold text-neutral-900 dark:text-neutral-100 text-center"
  >
    {portfolioTitle}
  </h3>
  <ul class="gap-3 grid sm:grid-cols-2">
    {
      tradePatentPortfolio.map((item) => (
        <li class="bg-white dark:bg-neutral-900 px-4 py-3 border border-neutral-200 dark:border-neutral-700 rounded-xl">
          <p class="font-medium text-neutral-900 dark:text-neutral-100 text-sm">
            {item.label}
          </p>
          <p class="mt-0.5 text-neutral-600 dark:text-neutral-400 text-xs">
            {item.detail}
          </p>
        </li>
      ))
    }
  </ul>
</div>
