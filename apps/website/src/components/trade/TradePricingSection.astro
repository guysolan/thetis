---
import { tradeDistributorMarginPct } from "@/content/trade/tradeMarkets";

export interface Props {
  patientRrpTitle: string;
  patientRrpBody: string;
  hospitalRrpTitle: string;
  hospitalRrpBody: string;
  marginTitle: string;
  marginBody: string;
  manufacturingTitle: string;
  manufacturingBody: string;
}

const {
  patientRrpTitle,
  patientRrpBody,
  hospitalRrpTitle,
  hospitalRrpBody,
  marginTitle,
  marginBody,
  manufacturingTitle,
  manufacturingBody,
} = Astro.props;
---

<div class="mx-auto max-w-4xl w-full space-y-6">
  <div class="gap-4 grid md:grid-cols-2">
    <div
      class="bg-white dark:bg-neutral-900 p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl"
    >
      <h3 class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100">
        {patientRrpTitle}
      </h3>
      <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
        {patientRrpBody}
      </p>
    </div>
    <div
      class="bg-white dark:bg-neutral-900 p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl"
    >
      <h3 class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100">
        {hospitalRrpTitle}
      </h3>
      <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
        {hospitalRrpBody}
      </p>
    </div>
  </div>

  <div class="gap-4 grid md:grid-cols-2">
    <div class="bg-primary/5 p-5 border border-primary/30 rounded-xl">
      <h3 class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100">
        {marginTitle}
      </h3>
      <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
        {marginBody}
      </p>
      <p class="mt-3 font-semibold text-primary text-2xl tabular-nums">
        ~{tradeDistributorMarginPct}%
      </p>
      <p class="text-neutral-500 text-xs">gross margin vs local RRP</p>
    </div>
    <div
      class="bg-white dark:bg-neutral-900 p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl"
    >
      <h3 class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100">
        {manufacturingTitle}
      </h3>
      <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
        {manufacturingBody}
      </p>
    </div>
  </div>
</div>
