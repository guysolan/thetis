---
import { evidenceSources } from "@/content/evidence/evidenceStudies";
import { ExternalLink } from "lucide-astro";

export interface Props {
  title?: string;
  evidencePageHref?: string;
  evidencePageLabel?: string;
}

const {
  title = "Sources",
  evidencePageHref = "/evidence",
  evidencePageLabel = "Full evidence page",
} = Astro.props;
---

<div class="mx-auto max-w-4xl">
  <h4 class="mb-3 font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
    {title}
  </h4>
  <ul class="gap-3 grid sm:grid-cols-2 lg:grid-cols-3">
    {
      evidenceSources.map((source) => (
        <li class="flex flex-col bg-white dark:bg-neutral-900 px-3 py-2.5 border border-neutral-200 dark:border-neutral-700 rounded-lg">
          <p class="font-medium text-neutral-900 dark:text-neutral-100 text-xs leading-snug line-clamp-2">
            {source.shortTitle}
          </p>
          <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2">
            <a
              href={source.pdfHref}
              class="inline-flex items-center gap-1 text-primary text-xs hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              PDF
              <ExternalLink class="w-3 h-3 shrink-0" aria-hidden="true" />
            </a>
            {source.conferenceHref && source.conference && (
              <a
                href={source.conferenceHref}
                class="inline-flex items-center gap-1 text-neutral-600 dark:text-neutral-400 text-xs hover:text-primary hover:underline"
                target="_blank"
                rel="noopener noreferrer"
              >
                {source.conference.replace(/ \(.*\)$/, "")}
                <ExternalLink class="w-3 h-3 shrink-0" aria-hidden="true" />
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ul>
  <p class="mt-4 text-center">
    <a
      href={evidencePageHref}
      class="inline-flex items-center gap-1 text-primary text-sm underline underline-offset-2"
    >
      {evidencePageLabel}
      <ExternalLink class="w-3.5 h-3.5" aria-hidden="true" />
    </a>
  </p>
</div>
