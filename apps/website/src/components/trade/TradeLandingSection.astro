---
import ColorGradient from "@/components/ColorGradient.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { ArrowRight, Award, BadgeCheck, Stethoscope } from "lucide-astro";

export interface Props {
  title: string;
  tagline: string;
  treatmentNote: string;
  badges: string[];
  primaryCta: string;
  partnerHref: string;
  productImageAlt: string;
}

const {
  title,
  tagline,
  treatmentNote,
  badges,
  primaryCta,
  partnerHref,
  productImageAlt,
} = Astro.props;

const badgeIcons = [BadgeCheck, Award, Stethoscope];
---

<section class="border-neutral-200 border-b">
  <ColorGradient>
    <div class="mx-auto px-4 py-8 md:py-16 max-w-[1200px]">
      <div
        class="items-center gap-10 lg:gap-14 grid lg:grid-cols-[1.1fr_0.9fr]"
      >
        <div class="lg:text-left text-center">
          <h1
            class="mb-4 font-semibold text-neutral-900 dark:text-neutral-100 text-5xl md:text-5xl lg:text-5xl text-balance leading-[1.1] tracking-tight"
          >
            {title}
          </h1>

          <p
            class="mx-auto lg:mx-0 mt-2 mb-8 max-w-xl text-neutral-600 dark:text-neutral-400 text-2xl lg:text-left text-center leading-snug"
          >
            {tagline}
          </p>

          <ul
            class="flex sm:flex-row flex-col flex-wrap justify-center lg:justify-start gap-2.5 mb-8"
          >
            {
              badges.map((label, i) => {
                const Icon = badgeIcons[i % badgeIcons.length];
                return (
                  <li class="inline-flex items-center gap-2 bg-white/90 dark:bg-neutral-900/80 shadow-sm px-4 py-2.5 border border-primary/25 rounded-full font-medium text-neutral-800 dark:text-neutral-100 text-sm">
                    <Icon class="w-4 h-4 text-primary shrink-0" aria-hidden />
                    {label}
                  </li>
                );
              })
            }
          </ul>

          <div class="flex flex-col items-center lg:items-start gap-3">
            <a
              href={partnerHref}
              class={cn(buttonVariants({ size: "lg" }), "gap-2")}
            >
              {primaryCta}
              <ArrowRight class="w-4 h-4" />
            </a>
            <p
              class="max-w-md text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed"
            >
              {treatmentNote}
            </p>
          </div>
        </div>

        <div class="relative mx-auto w-full lg:max-w-none max-w-md">
          <div
            class="absolute -inset-3 bg-primary/15 blur-2xl rounded-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/images/night_splint_bed_top_square.jpg"
            alt={productImageAlt}
            width={640}
            height={640}
            class="relative shadow-2xl border border-white/60 dark:border-neutral-700 rounded-2xl w-full object-cover aspect-square"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </ColorGradient>
</section>
