---
import {
  tradeTargetMarkets,
  estimateAnnualRuptures,
  formatAnnualRuptures,
} from "@/content/trade/tradeMarkets";

export interface Props {
  tableHeaders: [string, string, string];
  marketsFootnote: string;
}

const { tableHeaders, marketsFootnote } = Astro.props;
---

<div class="mx-auto max-w-4xl w-full">
  <div
    class="overflow-x-auto bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-xl"
  >
    <table class="w-full text-sm text-left border-collapse">
      <thead>
        <tr class="bg-primary/10 border-primary border-b-2">
          {
            tableHeaders.map((header) => (
              <th class="px-3 py-2.5 font-semibold text-xs whitespace-nowrap">
                {header}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          tradeTargetMarkets.map((market) => {
            const annual = estimateAnnualRuptures(
              market.population,
              market.incidencePer100k,
            );
            return (
              <tr class="border-neutral-200 dark:border-neutral-700 border-b last:border-b-0">
                <td class="px-3 py-2.5 font-medium text-neutral-900 dark:text-neutral-100 whitespace-nowrap">
                  {market.region}
                </td>
                <td class="px-3 py-2.5 tabular-nums whitespace-nowrap">
                  <span class="font-semibold text-primary">
                    {market.incidenceLabel}
                  </span>
                  <span class="text-neutral-500"> / 100k</span>
                </td>
                <td class="px-3 py-2.5 font-semibold tabular-nums text-neutral-900 dark:text-neutral-100 whitespace-nowrap">
                  {formatAnnualRuptures(annual)}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-neutral-500 text-xs text-center leading-relaxed">
    {marketsFootnote}
  </p>
</div>
