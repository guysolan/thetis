---
import PartialStarRating from "@/components/reviews/PartialStarRating";
import {
  formatGlobalRatingsLabel,
  GLOBAL_REVIEW_AVERAGE,
} from "@/features/reviews/productReviewStats";
---

<div
  class="flex flex-row flex-wrap justify-start items-center gap-x-4 gap-y-2 text-lg"
>
  <div class="flex items-center gap-2">
    <p class="font-semibold">{GLOBAL_REVIEW_AVERAGE.toFixed(1)}</p>
    <PartialStarRating
      rating={GLOBAL_REVIEW_AVERAGE}
      size="md"
      idPrefix="star-rating-astro"
      client:load
    />
  </div>
  <p class="text-gray-600">{formatGlobalRatingsLabel()}</p>
</div>
