---
import {Image} from 'astro:assets';
import AchillesRuptureDrawing from '@/assets/drawings/achilles-drawing.svg';
import SubscribeBlock from '../CTA/SubscribeBlock.astro';
import type { Lang } from '@/config/languages';

export interface Props {
    title: string;
    lang?: Lang;
    /** Hero side illustration; omit for Achilles FAQ default */
    illustration?: "achilles" | "plantar-fasciitis" | "none";
}

const { title, lang = "en", illustration = "achilles" } = Astro.props;

const plantarFasciitisAlt: Record<Lang, string> = {
    en: "Side view of the foot showing plantar fascia inflammation at the heel",
    de: "Seitenansicht des Fußes mit Plantarfaszie-Entzündung an der Ferse",
    fr: "Vue latérale du pied montrant l'inflammation de la fascia plantaire au talon",
    es: "Vista lateral del pie con inflamación de la fascia plantar en el talón",
    it: "Vista laterale del piede con infiammazione della fascia plantare al tallone",
};

const translations = {
    en: "Get free recovery tips delivered to your inbox.",
    de: "Erhalten Sie kostenlose Genesungstipps direkt in Ihren Posteingang.",
    fr: "Recevez des conseils de récupération gratuits directement dans votre boîte mail.",
    es: "Recibe consejos de recuperación gratuitos en tu bandeja de entrada.",
    it: "Ricevi consigli di recupero gratuiti direttamente nella tua casella di posta.",
};

const subtitle = translations[lang] || translations.en;
---
<section class="flex lg:flex-row flex-col justify-between items-center gap-8 mx-auto px-4 py-12 max-w-7xl">
    <div class="flex-1 max-w-2xl">
        <h1 class="mb-6 font-semibold text-4xl md:text-5xl">{title}</h1>
        <div class="mb-8">
            <h3 class="text-gray-700 text-xl md:text-2xl">{subtitle}</h3>
        </div>
        <SubscribeBlock source="faq_article" variant="compact" lang={lang} />
    </div>
    {
        illustration === "achilles" ? (
            <Image
                class="hidden lg:block flex-shrink-0 max-h-[50vh] object-contain"
                height={600}
                width={450}
                src={AchillesRuptureDrawing}
                alt="Achilles tendon illustration"
            />
        ) : illustration === "plantar-fasciitis" ? (
            <img
                class="hidden lg:block flex-shrink-0 max-h-[50vh] w-auto object-contain"
                src="/images/guide/plantar-fasciitis/plantar-fasciitis-side-view.png"
                alt={plantarFasciitisAlt[lang]}
                width={450}
                height={600}
            />
        ) : null
    }
</section>

