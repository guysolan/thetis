---
import { translatedClinicians } from "@/components/reviews/content/professional-opinions";

const jamesDavis = translatedClinicians.find((c) => c.name === "Mr James Davis");
const quote =
  "When I tore my own Achilles tendon, the hardest part of the recovery was having to wear the hospital boot in bed at night for many weeks. My only option was to make myself a splint using plaster-cast materials and make-shift straps.";
const attribution =
  "Mr James Davis · Past President, British Orthopaedic Foot & Ankle Society";
---

<blockquote
  class="bg-white/50 mt-4 p-5 border-primary/30 border-l-4 rounded-r-xl"
>
  <p class="text-slate-700 text-sm italic leading-relaxed">"{quote}"</p>
  <footer class="mt-3 font-medium text-slate-500 text-xs">{attribution}</footer>
</blockquote>
