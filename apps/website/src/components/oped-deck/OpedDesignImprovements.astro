---
import type { opedPitchDesignReviews } from "@/features/oped-deck/opedDeckPitchContent";

interface Props {
  content: typeof opedPitchDesignReviews;
}

const { content } = Astro.props;
---

<div class="mx-auto max-w-5xl space-y-6">
  <div class="gap-6 grid md:grid-cols-2">
    <div class="bg-primary/5 p-5 border border-primary/30 rounded-xl">
      <h3 class="mb-4 font-semibold text-neutral-900 dark:text-neutral-100 text-sm uppercase tracking-widest">
        {content.strengthsTitle}
      </h3>
      <ul class="space-y-3">
        {
          content.strengths.map((item) => (
            <li class="bg-white dark:bg-neutral-900 p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
              <p class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
                {item.label}
              </p>
              <p class="mt-1 text-neutral-600 dark:text-neutral-400 text-xs leading-relaxed">
                {item.detail}
              </p>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="bg-amber-50 dark:bg-amber-950/20 p-5 border border-amber-200 dark:border-amber-800 rounded-xl">
      <h3 class="mb-4 font-semibold text-neutral-900 dark:text-neutral-100 text-sm uppercase tracking-widest">
        {content.improvementsTitle}
      </h3>
      <ul class="space-y-3">
        {
          content.improvements.map((item) => (
            <li class="bg-white dark:bg-neutral-900 p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
              <p class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
                {item.label}
              </p>
              <p class="mt-1 text-neutral-600 dark:text-neutral-400 text-xs leading-relaxed">
                {item.detail}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <ul class="gap-4 grid md:grid-cols-2">
    {
      content.featuredReviews.map((review) => (
        <li
          class:list={[
            "p-5 border rounded-xl shadow-sm",
            review.theme === "strength"
              ? "bg-white dark:bg-neutral-900 border-neutral-200 dark:border-neutral-700"
              : "bg-amber-50/50 dark:bg-amber-950/10 border-amber-200 dark:border-amber-800",
          ]}
        >
          <div class="flex gap-0.5 mb-2" aria-label={`${review.stars} out of 5 stars`}>
            {Array.from({ length: review.stars }, () => (
              <svg
                class="w-3.5 h-3.5 text-amber-400 fill-current"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            {review.stars < 5 &&
              Array.from({ length: 5 - review.stars }, () => (
                <svg
                  class="w-3.5 h-3.5 text-neutral-200 fill-current"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
          </div>
          {review.title && (
            <p class="mb-1 font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
              {review.title}
            </p>
          )}
          <p class="text-neutral-700 dark:text-neutral-300 text-sm italic leading-relaxed">
            "{review.quote}"
          </p>
          <p class="mt-3 font-medium text-primary text-xs">
            {review.name}
            {review.country ? ` · ${review.country}` : ""}
          </p>
        </li>
      ))
    }
  </ul>

  <p class="bg-white dark:bg-neutral-900 shadow-sm px-5 py-4 border border-primary/30 rounded-xl text-neutral-700 dark:text-neutral-300 text-sm text-center leading-relaxed">
    {content.opedOpportunity}
  </p>
</div>
