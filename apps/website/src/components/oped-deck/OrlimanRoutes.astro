---
import { orlimanPitchRoutes } from "@/features/oped-deck/orlimanDeckPitchContent";

const content = orlimanPitchRoutes;
const detailHighlightPattern =
  /(Thetis|Orliman|Spain|Portugal|Brazil|Spanish|Portuguese|ATR)/;

function formatRuptures(n: number) {
  if (n >= 10_000) {
    return `~${Math.round(n / 1_000)}k`;
  }
  return n.toLocaleString("en-GB");
}

function isDetailHighlight(part: string) {
  return (
    part === "Thetis" ||
    part === "Orliman" ||
    part === "Spain" ||
    part === "Portugal" ||
    part === "Brazil" ||
    part === "Spanish" ||
    part === "Portuguese" ||
    part === "ATR"
  );
}
---

<div class="space-y-6 mx-auto max-w-5xl">
  <div
    class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-2xl text-center"
  >
    <p
      class="font-bold tabular-nums text-neutral-900 dark:text-neutral-100 text-3xl md:text-4xl"
    >
      {content.marketHeadline}
    </p>
    <p
      class="mx-auto mt-2 max-w-2xl text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed"
    >
      {content.marketIntro}
    </p>
    <p class="mt-2 text-neutral-500 text-xs">{content.marketSource}</p>
  </div>

  <div class="bg-primary/5 p-5 border border-primary/30 rounded-2xl">
    <p class="mb-4 font-medium text-primary text-sm uppercase tracking-widest">
      {content.leadLabel}
    </p>
    <p
      class="text-neutral-800 dark:text-neutral-200 text-base md:text-lg leading-relaxed"
    >
      {
        content.leadBody
          .split(detailHighlightPattern)
          .map((part) =>
            isDetailHighlight(part) ? (
              <strong class="font-semibold text-neutral-900 dark:text-neutral-100">
                {part}
              </strong>
            ) : (
              part
            ),
          )
      }
    </p>
  </div>

  <div>
    <p
      class="mb-3 font-medium text-neutral-500 text-sm text-center uppercase tracking-widest"
    >
      {content.otherRoutesTitle}
    </p>
    <ul class="gap-3 grid md:grid-cols-3">
      {
        content.otherRoutes.map((route) => (
          <li class="bg-white dark:bg-neutral-900 shadow-sm p-4 border border-neutral-200 dark:border-neutral-700 rounded-xl">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl leading-none" aria-hidden="true">
                {route.flag}
              </span>
              <div>
                <p class="font-bold text-neutral-900 dark:text-neutral-100 text-base leading-tight">
                  {route.market}
                </p>
                <p class="font-medium text-primary text-sm">{route.channel}</p>
              </div>
            </div>
            <p class="mb-2 font-bold tabular-nums text-neutral-900 dark:text-neutral-100 text-lg">
              {formatRuptures(route.annualRuptures)} ATR ruptures / year
            </p>
            <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
              {route.detail
                .split(detailHighlightPattern)
                .map((part) =>
                  isDetailHighlight(part) ? (
                    <strong class="font-semibold text-neutral-800 dark:text-neutral-200">
                      {part}
                    </strong>
                  ) : (
                    part
                  ),
                )}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</div>
