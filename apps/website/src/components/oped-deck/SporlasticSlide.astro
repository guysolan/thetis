---
import ColorGradient from "@/components/ColorGradient.astro";
import { Check, X } from "lucide-astro";
import DeckSection from "./DeckSection.astro";
import OpedDesignReviews from "./OpedDesignReviews.astro";
import OpedDeckSleepSurveyChart from "./OpedDeckSleepSurveyChart";
import OpedPatientComplaintSurveyResults from "./OpedPatientComplaintSurveyResults";
import OpedProofCards from "./OpedProofCards.astro";
import OpedSalesGrowthChart from "./OpedSalesGrowthChart.astro";
import PitchStatGrid from "./PitchStatGrid.astro";
import SlideSplit from "./SlideSplit.astro";
import {
  sporlasticGenerativeDesignMockup,
  sporlasticPfNightSplintDorsiflexion,
  sporlasticPitchDayStack,
  sporlasticPitchGermanyReimbursement,
  sporlasticPitchManufacturing,
  sporlasticPitchPartnershipOptions,
  sporlasticPitchProduct,
  sporlasticPitchRegulatory,
  sporlasticPitchSalesChart,
  sporlasticPitchWhyNow,
} from "@/features/oped-deck/sporlasticDeckPitchContent";
import {
  opedPitchClinical,
  opedPitchDesignReviews,
  opedPitchIp,
  opedPitchPatientComplaint,
} from "@/features/oped-deck/opedDeckPitchContent";

interface Props {
  page: number;
}

const { page } = Astro.props;
---

{
  page === 1 && (
    <div class="pb-20 w-full min-h-[calc(100vh-57px)]">
      <div class="[&_.color-gradient]:!pt-6">
        <ColorGradient>
          <div class="mx-auto px-6 md:px-12 lg:px-24 py-6 md:py-10 w-full max-w-6xl text-center">
            <p class="mb-6 font-medium text-primary text-sm uppercase tracking-widest">
              SPORLASTIC x Thetis Medical
            </p>
            <div class="relative mx-auto mb-6 w-full max-w-[11rem] md:max-w-48">
              <div
                class="absolute -inset-3 bg-primary/10 blur-2xl rounded-3xl"
                aria-hidden="true"
              />
              <img
                src="/images/night_splint_bed_top_square.jpg"
                alt="Thetis Achilles rupture night splint"
                width="640"
                height="640"
                class="relative shadow-md border border-white/70 rounded-2xl w-full object-cover aspect-square"
              />
            </div>
            <h1 class="mx-auto mb-4 w-full max-w-6xl font-semibold text-neutral-900 text-3xl md:text-4xl lg:text-5xl text-balance leading-[1.1] tracking-tight">
              The missing night-time product for Achilles rupture recovery.
            </h1>
            <p class="mx-auto w-full max-w-5xl text-neutral-600 text-lg md:text-xl leading-snug">
              SPORLASTIC already protects ATR patients by day with SP AIR
              WALKER. Thetis has the proven night splint patients need — and
              your textile manufacturing expertise is exactly what it takes to
              scale it.
            </p>
          </div>
        </ColorGradient>
      </div>
    </div>
  )
}

{
  page === 2 && (
    <DeckSection
      title={sporlasticPitchDayStack.title}
      intro={sporlasticPitchDayStack.intro}
      eyebrow={sporlasticPitchDayStack.eyebrow}
      gradient
    >
      <div class="space-y-6 mx-auto max-w-5xl">
        <ul class="gap-5 grid md:grid-cols-3">
          {sporlasticPitchDayStack.products.map((product) => (
            <li class="bg-white dark:bg-neutral-900 shadow-sm border border-neutral-200 dark:border-neutral-700 rounded-2xl overflow-hidden">
              <div class="flex justify-center items-center bg-white dark:bg-white aspect-[4/3]">
                <img
                  src={product.image}
                  alt={product.imageAlt}
                  width={640}
                  height={480}
                  class="w-[75%] h-[75%] object-contain"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <p class="mb-1 font-medium text-[10px] text-primary uppercase tracking-widest">
                  {product.role}
                </p>
                <p class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl">
                  {product.name}
                </p>
                <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                  {product.detail}
                </p>
                {"productUrl" in product && product.productUrl && (
                  <a
                    href={product.productUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block mt-3 font-medium text-primary text-xs hover:underline"
                  >
                    View on sporlastic.de
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </DeckSection>
  )
}

{
  page === 3 && (
    <DeckSection
      title={sporlasticPitchProduct.title}
      intro={sporlasticPitchProduct.intro}
      eyebrow={sporlasticPitchProduct.eyebrow}
      gradient
    >
      <div class="space-y-6 mx-auto max-w-5xl">
        <PitchStatGrid stats={sporlasticPitchProduct.stats} columns={4} />
        <ul class="gap-3 grid sm:grid-cols-2">
          {sporlasticPitchProduct.features.map((feature) => (
            <li class="flex gap-2 bg-white dark:bg-neutral-900 shadow-sm p-4 border border-neutral-200 dark:border-neutral-700 rounded-xl text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
              <Check
                class="mt-0.5 w-4 h-4 text-primary shrink-0"
                aria-hidden="true"
              />
              {feature}
            </li>
          ))}
        </ul>
        <div class="gap-2 grid sm:grid-cols-3">
          {sporlasticPitchProduct.notItems.map((item) => (
            <p class="flex gap-2 bg-neutral-100 dark:bg-neutral-800/50 px-3 py-2 rounded-lg text-neutral-600 dark:text-neutral-400 text-sm">
              <X
                class="mt-0.5 w-4 h-4 text-neutral-400 shrink-0"
                aria-hidden="true"
              />
              {item}
            </p>
          ))}
        </div>
      </div>
    </DeckSection>
  )
}

{
  page === 4 && (
    <DeckSection
      title={opedPitchPatientComplaint.title}
      intro={opedPitchPatientComplaint.intro}
      eyebrow={opedPitchPatientComplaint.eyebrow}
      gradient
      compact
    >
      <div>
        <OpedPatientComplaintSurveyResults client:visible />
        <OpedDeckSleepSurveyChart client:load />
      </div>
    </DeckSection>
  )
}

{
  page === 5 && (
    <DeckSection
      title={sporlasticPitchGermanyReimbursement.title}
      intro={sporlasticPitchGermanyReimbursement.intro}
      eyebrow={sporlasticPitchGermanyReimbursement.eyebrow}
      gradient
    >
      <div class="space-y-6 mx-auto max-w-5xl">
        <div class="bg-primary/5 p-4 border border-primary/30 rounded-2xl">
          <p class="mb-4 font-medium text-primary text-sm uppercase tracking-widest">
            {sporlasticPitchGermanyReimbursement.germanyLabel}
          </p>
          <div
            class="items-start gap-6 grid lg:grid-cols-[minmax(0,1fr)_minmax(0,2fr)]"
          >
            <div>
              <figure
                class="bg-white dark:bg-neutral-900 shadow-sm p-3 border border-neutral-200 dark:border-neutral-700 rounded-2xl"
              >
                <div class="bg-neutral-50 rounded-lg overflow-hidden">
                  <img
                    src={sporlasticPfNightSplintDorsiflexion.src}
                    alt={sporlasticPfNightSplintDorsiflexion.alt}
                    width={640}
                    height={480}
                    class="w-full h-auto max-h-40 object-contain"
                    loading="lazy"
                  />
                </div>
                <figcaption
                  class="mt-2 text-neutral-600 dark:text-neutral-400 text-xs text-center leading-snug"
                >
                  {sporlasticPfNightSplintDorsiflexion.caption}
                </figcaption>
              </figure>
              <div
                class="relative mt-4 bg-primary/15 shadow-md p-4 border-2 border-primary/50 rounded-xl overflow-hidden"
                role="note"
              >
                <div
                  class="absolute inset-y-0 left-0 bg-primary w-1.5"
                  aria-hidden="true"
                />
                <p
                  class="mb-1 font-bold text-primary text-[10px] uppercase tracking-[0.14em]"
                >
                  {sporlasticPitchGermanyReimbursement.wedgeNote.label}
                </p>
                <p
                  class="font-bold text-neutral-900 dark:text-neutral-100 text-sm md:text-base leading-snug"
                >
                  {sporlasticPitchGermanyReimbursement.wedgeNote.headline}
                </p>
                <p
                  class="mt-1.5 font-semibold text-neutral-800 dark:text-neutral-200 text-xs md:text-sm leading-snug"
                >
                  {sporlasticPitchGermanyReimbursement.wedgeNote.detail}
                </p>
              </div>
            </div>

            <div class="space-y-4">
              <p
                class="font-medium text-neutral-900 dark:text-neutral-100 text-sm"
              >
                {sporlasticPitchGermanyReimbursement.hilfsmittelGroup}
              </p>
              <p
                class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed"
              >
                {sporlasticPitchGermanyReimbursement.hilfsmittelNote}
              </p>
              <ul class="gap-2 grid">
                {sporlasticPitchGermanyReimbursement.listedCodes.map((item) => (
                  <li class="bg-white dark:bg-neutral-900 shadow-sm px-3 py-2 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                    <p class="font-mono font-semibold text-primary text-sm">
                      {item.code}
                    </p>
                    <p class="font-medium text-neutral-900 dark:text-neutral-100 text-sm">
                      {item.product}
                    </p>
                    <p class="text-neutral-600 dark:text-neutral-400 text-xs leading-snug">
                      {item.detail}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <ul class="gap-3 grid md:grid-cols-3">
          {sporlasticPitchGermanyReimbursement.limitations.map((item) => (
            <li class="bg-white dark:bg-neutral-900 shadow-sm p-4 border border-neutral-200 dark:border-neutral-700 rounded-xl">
              <p class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-sm">
                {item.label}
              </p>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                {item.detail}
              </p>
            </li>
          ))}
        </ul>

        <p
          class="text-neutral-800 dark:text-neutral-200 text-sm md:text-base text-center leading-relaxed"
        >
          {sporlasticPitchGermanyReimbursement.closing}
        </p>
      </div>
    </DeckSection>
  )
}

{
  page === 6 && (
    <DeckSection
      title={opedPitchDesignReviews.title}
      intro={opedPitchDesignReviews.intro}
      eyebrow="Online launch"
      gradient
    >
      <OpedDesignReviews content={opedPitchDesignReviews} />
    </DeckSection>
  )
}

{
  page === 7 && (
    <DeckSection
      title="Surgeons say yes"
      intro="Leading foot and ankle surgeons recommend the splint for night-time use — the problem the walking boot cannot solve."
      eyebrow="Proof"
      gradient
    >
      <OpedProofCards />
    </DeckSection>
  )
}

{
  page === 8 && (
    <DeckSection
      title={opedPitchClinical.title}
      intro={opedPitchClinical.intro}
      eyebrow="Safety evidence"
      gradient
    >
      <div class="space-y-6 mx-auto max-w-5xl">
        <PitchStatGrid stats={opedPitchClinical.stats} columns={3} />
        <div class="space-y-4 bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl">
          <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
            {opedPitchClinical.body}
          </p>
          <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed">
            {opedPitchClinical.surveillance}
          </p>
        </div>
        <ul class="gap-2 grid sm:grid-cols-3">
          {opedPitchClinical.sources.map((source) => (
            <li class="bg-primary/5 px-3 py-2 border border-primary/20 rounded-lg font-medium text-neutral-700 dark:text-neutral-300 text-xs text-center">
              {source}
            </li>
          ))}
        </ul>
      </div>
    </DeckSection>
  )
}

{
  page === 9 && (
    <DeckSection
      title={opedPitchIp.title}
      intro={opedPitchIp.intro}
      eyebrow="IP portfolio"
      gradient
    >
      <div class="space-y-6 mx-auto max-w-5xl">
        <p class="font-medium text-primary text-sm uppercase tracking-widest">
          {opedPitchIp.portfolioTitle}
        </p>
        <ul class="gap-3 grid sm:grid-cols-2">
          {opedPitchIp.portfolio.map((item) => (
            <li class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl">
              <p class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
                {item.label}
              </p>
              <p class="mt-1 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                {item.detail}
              </p>
            </li>
          ))}
        </ul>
        <div class="bg-primary/5 p-5 border border-primary/30 rounded-xl">
          <p class="text-neutral-800 dark:text-neutral-200 text-sm leading-relaxed">
            {opedPitchIp.message}
          </p>
          <p class="mt-2 text-neutral-500 text-xs">{opedPitchIp.licenceNote}</p>
        </div>
      </div>
    </DeckSection>
  )
}

{
  page === 10 && (
    <DeckSection
      title={sporlasticPitchRegulatory.title}
      intro={sporlasticPitchRegulatory.intro}
      eyebrow="Regulatory & quality"
      gradient
    >
      <div class="space-y-7 mx-auto max-w-5xl">
        {sporlasticPitchRegulatory.sections.map((section) => (
          <div>
            <p class="mb-3 font-medium text-primary text-sm uppercase tracking-widest">
              {section.title}
            </p>
            <ul class="gap-3 grid sm:grid-cols-2 lg:grid-cols-3">
              {section.items.map((item) => (
                <li class="bg-white dark:bg-neutral-900 shadow-sm p-4 border border-neutral-200 dark:border-neutral-700 rounded-xl">
                  <p class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
                    {item.label}
                  </p>
                  <p class="mt-1 text-neutral-600 dark:text-neutral-400 text-sm leading-snug">
                    {item.detail}
                  </p>
                </li>
              ))}
            </ul>
          </div>
        ))}
        <p class="text-neutral-500 text-xs text-center">
          {sporlasticPitchRegulatory.footnote}
        </p>
      </div>
    </DeckSection>
  )
}

{
  page === 11 && (
    <DeckSection
      title={sporlasticPitchWhyNow.title}
      intro={sporlasticPitchWhyNow.intro}
      eyebrow="Partnership context"
      gradient
    >
      <div class="space-y-6 mx-auto max-w-4xl">
        <ul class="gap-4 grid md:grid-cols-3">
          {sporlasticPitchWhyNow.growthPoints.map((point) => (
            <li class="bg-white dark:bg-neutral-900 shadow-sm p-6 border border-neutral-200 dark:border-neutral-700 rounded-xl">
              <p class="font-bold text-neutral-900 dark:text-neutral-100 text-base md:text-lg leading-snug">
                {point.label}
              </p>
              <p class="mt-2 text-neutral-600 dark:text-neutral-400 text-sm md:text-base leading-snug">
                {point.value}
              </p>
            </li>
          ))}
        </ul>
        <OpedSalesGrowthChart chart={sporlasticPitchSalesChart} />
      </div>
    </DeckSection>
  )
}

{
  page === 12 && (
    <DeckSection
      title={sporlasticPitchManufacturing.title}
      intro={sporlasticPitchManufacturing.intro}
      eyebrow={sporlasticPitchManufacturing.eyebrow}
      gradient
    >
      <SlideSplit class="mx-auto max-w-5xl">
        <div slot="copy">
          <div class="relative">
            <div
              class="absolute -inset-2 bg-primary/10 blur-xl rounded-2xl"
              aria-hidden="true"
            />
            <img
              src={sporlasticGenerativeDesignMockup.src}
              alt={sporlasticGenerativeDesignMockup.alt}
              width="640"
              height="640"
              class="relative shadow-sm border border-neutral-200 dark:border-neutral-700 rounded-2xl w-full object-cover aspect-square"
              loading="lazy"
            />
          </div>
          <p class="mt-3 text-neutral-500 dark:text-neutral-400 text-xs leading-snug">
            {sporlasticGenerativeDesignMockup.caption}
          </p>
        </div>
        <ul class="gap-4 grid">
          {sporlasticPitchManufacturing.points.map((point) => (
            <li class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-xl">
              <p class="mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-base">
                {point.label}
              </p>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                {point.detail}
              </p>
            </li>
          ))}
        </ul>
      </SlideSplit>
    </DeckSection>
  )
}

{
  page === 13 && (
    <DeckSection
      title={sporlasticPitchPartnershipOptions.title}
      intro={sporlasticPitchPartnershipOptions.intro}
      eyebrow="Next step"
      gradient
    >
      <div class="space-y-6 mx-auto max-w-4xl">
        <ul class="gap-4 grid md:grid-cols-2">
          {sporlasticPitchPartnershipOptions.options.map((option) => (
            <li class="flex flex-col bg-white dark:bg-neutral-900 shadow-sm p-6 border border-neutral-200 dark:border-neutral-700 rounded-xl">
              <p class="font-medium text-primary text-xs uppercase tracking-widest">
                {option.label}
              </p>
              <h3 class="mt-0.5 mb-2 font-bold text-neutral-900 dark:text-neutral-100 text-xl">
                {option.title}
              </h3>
              <p class="mb-4 text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                {option.summary}
              </p>
              <ul class="space-y-2 mt-auto">
                {option.points.map((point) => (
                  <li class="flex gap-2 text-neutral-700 dark:text-neutral-300 text-sm">
                    <Check
                      class="mt-0.5 w-4 h-4 text-primary shrink-0"
                      aria-hidden="true"
                    />
                    {point}
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>

        <p class="text-neutral-500 text-sm text-center">
          {sporlasticPitchPartnershipOptions.closing}
        </p>
      </div>
    </DeckSection>
  )
}
