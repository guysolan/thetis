---
import PartialStarRating from "@/components/reviews/PartialStarRating";
import {
  formatReviewSummary,
  GLOBAL_REVIEW_AVERAGE,
} from "@/features/reviews/productReviewStats";

interface Props {
  rating?: number;
  price: string;
}

const { rating = GLOBAL_REVIEW_AVERAGE, price } = Astro.props;
---

<div class="space-y-4 mt-4" data-oped-product-listing>
  <div class="flex items-center gap-2">
    <PartialStarRating
      rating={rating}
      size="sm"
      idPrefix="oped-listing"
      client:load
    />
    <span class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
      {formatReviewSummary()}
    </span>
  </div>

  <button
    type="button"
    data-oped-buy-btn
    class="inline-flex justify-center items-center bg-primary hover:bg-primary/90 px-6 py-3 rounded-lg w-full sm:w-auto font-semibold text-white text-sm transition-colors"
  >
    Buy now for {price}
  </button>
  <div
    data-oped-example-toast
    class="hidden bg-primary/10 px-4 py-3 border border-primary/20 rounded-lg font-medium text-primary text-sm"
    role="status"
    aria-live="polite"
  >
    Example purposes only.
  </div>

  <div class="mx-auto py-4 border-neutral-200 border-t w-full max-w-md">
    <div class="flex flex-col space-y-4">
      <div class="flex flex-row justify-between items-center">
        <p class="font-semibold text-lg">Choose your Options</p>
        <button
          type="button"
          data-oped-size-toggle
          class="font-semibold text-md text-primary underline underline-offset-2 cursor-pointer"
        >
          What Size am I?
        </button>
      </div>

      <div
        data-oped-size-calculator
        class="hidden flex-col space-y-4 bg-neutral-50 p-4 rounded-lg"
      >
        <div class="flex flex-col space-y-2">
          <label class="font-medium text-sm" for="oped-size-region"
            >Region:</label
          >
          <select
            id="oped-size-region"
            data-oped-size-region
            class="px-3 py-2 border border-neutral-300 rounded-md"
          >
            <option value="EU">EU</option>
            <option value="UK" selected>UK</option>
            <option value="US Men">US Men</option>
            <option value="US Women">US Women</option>
          </select>
        </div>

        <div class="flex flex-col space-y-2">
          <label class="font-medium text-sm" for="oped-shoe-size"
            >Your Shoe Size:</label
          >
          <input
            id="oped-shoe-size"
            data-oped-shoe-size
            type="number"
            step="0.5"
            placeholder="Enter your shoe size"
            class="px-3 py-2 border border-neutral-300 rounded-md"
          />
        </div>

        <div
          data-oped-size-result
          class="hidden bg-primary/10 mt-4 p-4 rounded-md"
        >
          <p class="font-semibold text-center">
            Recommended Size:
            <span data-oped-size-result-value class="text-primary text-lg"
            ></span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <div
      class="inline-flex items-center gap-0.5 bg-white dark:bg-neutral-800 px-0.5 py-0.5 border border-neutral-200 rounded-md h-8"
      data-oped-size-group
    >
      <button
        type="button"
        data-oped-variant="size"
        data-value="large"
        aria-pressed="true"
        class="inline-flex justify-center items-center bg-primary shadow-sm px-3 py-1 rounded-sm font-medium text-md text-white transition-all"
      >
        Large
      </button>
      <button
        type="button"
        data-oped-variant="size"
        data-value="small"
        aria-pressed="false"
        class="inline-flex justify-center items-center px-3 py-1 rounded-sm font-medium text-md text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 dark:text-neutral-400 transition-all"
      >
        Small
      </button>
    </div>

    <div
      class="inline-flex items-center gap-0.5 bg-white dark:bg-neutral-800 px-0.5 py-0.5 border border-neutral-200 rounded-md h-8"
      data-oped-side-group
    >
      <button
        type="button"
        data-oped-variant="side"
        data-value="left"
        aria-pressed="true"
        class="inline-flex justify-center items-center bg-primary shadow-sm px-3 py-1 rounded-sm font-medium text-md text-white transition-all"
      >
        Left
      </button>
      <button
        type="button"
        data-oped-variant="side"
        data-value="right"
        aria-pressed="false"
        class="inline-flex justify-center items-center px-3 py-1 rounded-sm font-medium text-md text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 dark:text-neutral-400 transition-all"
      >
        Right
      </button>
    </div>
  </div>
</div>

<script>
  const sizeThresholds = {
    EU: 42,
    UK: 8,
    "US Men": 9,
    "US Women": 10.5,
  } as const;

  function initProductListing(root: HTMLElement) {
    if (!root || root.dataset.initialized === "true") return;
    root.dataset.initialized = "true";

    const buyBtn = root.querySelector("[data-oped-buy-btn]");
    const exampleToast = root.querySelector("[data-oped-example-toast]");
    const sizeToggle = root.querySelector("[data-oped-size-toggle]");
    const calculator = root.querySelector("[data-oped-size-calculator]");
    const regionSelect = root.querySelector("[data-oped-size-region]");
    const shoeSizeInput = root.querySelector("[data-oped-shoe-size]");
    const sizeResult = root.querySelector("[data-oped-size-result]");
    const sizeResultValue = root.querySelector("[data-oped-size-result-value]");

    buyBtn?.addEventListener("click", () => {
      if (exampleToast instanceof HTMLElement) {
        exampleToast.classList.remove("hidden");
        window.setTimeout(() => exampleToast.classList.add("hidden"), 2500);
      }
    });

    sizeToggle?.addEventListener("click", () => {
      calculator?.classList.toggle("hidden");
      calculator?.classList.toggle("flex");
    });

    function updateRecommendedSize() {
      if (
        !(regionSelect instanceof HTMLSelectElement) ||
        !(shoeSizeInput instanceof HTMLInputElement) ||
        !(sizeResult instanceof HTMLElement) ||
        !(sizeResultValue instanceof HTMLElement)
      ) {
        return;
      }

      const size = Number.parseFloat(shoeSizeInput.value);
      const threshold =
        sizeThresholds[regionSelect.value as keyof typeof sizeThresholds] ??
        sizeThresholds.UK;

      if (!Number.isFinite(size)) {
        sizeResult.classList.add("hidden");
        return;
      }

      sizeResultValue.textContent = size < threshold ? "Small" : "Large";
      sizeResult.classList.remove("hidden");
    }

    regionSelect?.addEventListener("change", updateRecommendedSize);
    shoeSizeInput?.addEventListener("input", updateRecommendedSize);

    root.querySelectorAll("[data-oped-variant]").forEach((button: Element) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;

        const group =
          button.dataset.opedVariant === "size"
            ? root.querySelector("[data-oped-size-group]")
            : root.querySelector("[data-oped-side-group]");

        group
          ?.querySelectorAll("[data-oped-variant]")
          .forEach((peer: Element) => {
            if (!(peer instanceof HTMLButtonElement)) return;
            const active = peer === button;
            peer.setAttribute("aria-pressed", String(active));
            peer.classList.toggle("bg-primary", active);
            peer.classList.toggle("text-white", active);
            peer.classList.toggle("shadow-sm", active);
            peer.classList.toggle("text-neutral-500", !active);
            peer.classList.toggle("dark:text-neutral-400", !active);
          });
      });
    });
  }

  document
    .querySelectorAll("[data-oped-product-listing]")
    .forEach((root: Element) => {
      if (root instanceof HTMLElement) initProductListing(root);
    });

  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll("[data-oped-product-listing]")
      .forEach((root: Element) => {
        if (root instanceof HTMLElement) initProductListing(root);
      });
  });
</script>
