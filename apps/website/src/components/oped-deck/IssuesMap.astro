---
import { Moon, Sun } from "lucide-astro";
import { opedVacopedIssues } from "@/features/oped-deck/opedDeckContent";

interface Props {
  highlightId?: (typeof opedVacopedIssues)[number]["id"];
}

const { highlightId } = Astro.props;

const iconClass = (highlighted: boolean) =>
  highlighted ? "w-6 h-6 text-primary" : "w-6 h-6 text-slate-600";
---

<ul class="gap-4 grid md:grid-cols-3 mx-auto max-w-5xl">
  {
    opedVacopedIssues.map((issue) => {
      const highlighted = highlightId === issue.id;

      return (
        <li
          class:list={[
            "flex flex-col bg-white/50 shadow-sm p-6 border rounded-xl",
            highlighted
              ? "border-primary shadow-md ring-2 ring-primary/20"
              : "border-slate-200",
          ]}
        >
          <div
            class:list={[
              "flex justify-center items-center mb-4 rounded-xl w-12 h-12",
              highlighted ? "bg-primary/15" : "bg-slate-100",
            ]}
          >
            {issue.icon === "shower" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class={iconClass(highlighted)}
                aria-hidden="true"
              >
                <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z" />
              </svg>
            )}
            {issue.icon === "sleep" && (
              <Moon class={iconClass(highlighted)} aria-hidden="true" />
            )}
            {issue.icon === "wound" && (
              <Sun class={iconClass(highlighted)} aria-hidden="true" />
            )}
          </div>
          <h3 class="font-semibold text-slate-800 text-lg">{issue.title}</h3>
          <p class="mt-2 text-slate-600 text-sm leading-relaxed">
            {issue.summary}
          </p>
        </li>
      );
    })
  }
</ul>
