---
interface Props {
  quote: string;
  name: string;
  country?: string;
  stars?: number;
  class?: string;
  large?: boolean;
}

const { quote, name, country, stars = 5, class: className = "", large = false } =
  Astro.props;
---

<figure
  class:list={[
    "relative text-center py-6 px-6 md:px-10",
    className,
  ]}
>
  <img
    src="/images/quote-mark.svg"
    alt=""
    aria-hidden="true"
    width="40"
    height="40"
    class="mx-auto mb-3 opacity-30"
  />

  {
    stars > 0 && (
      <div
        class="flex justify-center gap-0.5 mb-4"
        aria-label={`${stars} out of 5 stars`}
      >
        {Array.from({ length: stars }, () => (
          <svg
            class="w-4 h-4 text-amber-400 fill-current"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
    )
  }

  <blockquote>
    <p
      class:list={[
        "font-semibold text-neutral-900 italic leading-snug",
        large ? "text-xl md:text-2xl" : "text-base md:text-lg",
      ]}
    >
      "{quote}"
    </p>
  </blockquote>

  <figcaption class="mt-4 font-medium text-primary text-sm">
    {name}{country ? ` · ${country}` : ""}
  </figcaption>
</figure>
