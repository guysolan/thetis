---
import {
  opedSleepDiscomfortSegments,
  opedSleepDiscomfortTotal,
} from "@/features/oped-deck/opedDeckContent";

function pct(count: number) {
  return Math.round((count / opedSleepDiscomfortTotal) * 100);
}

const fills = {
  uncomfortable: "bg-primary",
  hot: "bg-amber-500",
  dirty: "bg-amber-600",
} as const;
---

<div class="bg-white/50 p-5 border border-slate-200 rounded-xl">
  <p class="mb-1 font-semibold text-slate-800 text-sm">Why boot sleep fails</p>
  <p class="mb-4 text-slate-500 text-xs">
    Patient-reported themes (n={opedSleepDiscomfortTotal} responses, multiple selections
    allowed)
  </p>
  <ul class="space-y-3">
    {
      opedSleepDiscomfortSegments.map((segment) => (
        <li>
          <div class="flex justify-between gap-3 mb-1 text-sm">
            <span class="font-medium text-slate-800">{segment.label}</span>
            <span class="tabular-nums text-slate-500">
              {pct(segment.count)}%
            </span>
          </div>
          <div class="bg-slate-100 rounded-full h-2 overflow-hidden">
            <div
              class:list={["rounded-full h-full", fills[segment.key]]}
              style={`width: ${pct(segment.count)}%`}
            />
          </div>
        </li>
      ))
    }
  </ul>
</div>
