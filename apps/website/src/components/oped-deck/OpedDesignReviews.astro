---
import OpedDeckProductListing from "./OpedDeckProductListing.astro";
import ProductReviews from "@/components/reviews/ProductReviews";
import type { opedPitchDesignReviews } from "@/features/oped-deck/opedDeckPitchContent";

interface Props {
  content: typeof opedPitchDesignReviews;
}

const { content } = Astro.props;
const productListing = content.productListing;
---

<div class="space-y-6 mx-auto max-w-5xl">
  <div class="space-y-5">
    <div
      class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-2xl"
    >
      <div class="items-start gap-5 grid sm:grid-cols-[0.9fr_1.1fr]">
        <div class="relative">
          <div
            class="absolute -inset-3 bg-primary/10 blur-2xl rounded-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/images/night_splint_bed_top_square.jpg"
            alt="Thetis Achilles rupture night splint"
            width="640"
            height="640"
            class="relative shadow-sm border border-white/70 dark:border-neutral-700 rounded-2xl w-full object-cover aspect-square"
          />
        </div>

        <div>
          <div
            class="inline-flex items-center gap-2 bg-primary/10 mb-3 px-3 py-1.5 rounded-full"
          >
            <span
              class="font-semibold text-[11px] text-primary uppercase tracking-wider"
            >
              {productListing.badge}
            </span>
          </div>
          <h3
            class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100 text-2xl leading-tight"
          >
            {productListing.title}
          </h3>
          <p
            class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed"
          >
            {productListing.description}
          </p>

          <OpedDeckProductListing
            rating={productListing.rating}
            price={productListing.price}
          />
        </div>
      </div>
    </div>

    <div
      class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-2xl"
    >
      <ProductReviews variant="deck" client:load />
    </div>
  </div>
</div>
