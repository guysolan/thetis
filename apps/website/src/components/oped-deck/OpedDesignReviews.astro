---
import OpedDeckProductListing from "./OpedDeckProductListing.astro";
import type { opedPitchDesignReviews } from "@/features/oped-deck/opedDeckPitchContent";
import masterReviewsData from "@/data/master-reviews.json";
import {
  formatReviewMeta,
  getSourceLabel,
  type MasterReview,
} from "@/features/reviews/productReviews";

interface Props {
  content: typeof opedPitchDesignReviews;
}

const { content } = Astro.props;
const reviewSnapshot = content.reviewSnapshot;
const productListing = content.productListing;

const allReviews = masterReviewsData.reviews as MasterReview[];
const fiveStarExamples = allReviews
  .filter((review) => review.stars === 5)
  .slice(0, 5)
  .map((review) => ({
    stars: review.stars,
    source: getSourceLabel(review),
    verified: Boolean(review.verified ?? review.style?.verified),
    hasText: review.hasText,
    title: review.title ?? "",
    body: review.body ?? review.excerpt ?? "",
    name: review.name ?? "Customer",
    meta: formatReviewMeta(review) ?? "",
  }));

const showingText = `Showing ${fiveStarExamples.length} of ${reviewSnapshot.totalRatings} reviews`;
---

<div class="space-y-6 mx-auto max-w-5xl">
  <div class="space-y-5">
    <div
      class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-2xl"
    >
      <div class="items-start gap-5 grid sm:grid-cols-[0.9fr_1.1fr]">
        <div class="relative">
          <div
            class="absolute -inset-3 bg-primary/10 blur-2xl rounded-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/images/night_splint_bed_top_square.jpg"
            alt="Thetis Achilles rupture night splint"
            width="640"
            height="640"
            class="relative shadow-sm border border-white/70 dark:border-neutral-700 rounded-2xl w-full object-cover aspect-square"
          />
        </div>

        <div>
          <div
            class="inline-flex items-center gap-2 bg-primary/10 mb-3 px-3 py-1.5 rounded-full"
          >
            <span
              class="font-semibold text-[11px] text-primary uppercase tracking-wider"
            >
              {productListing.badge}
            </span>
          </div>
          <h3
            class="mb-2 font-semibold text-neutral-900 dark:text-neutral-100 text-2xl leading-tight"
          >
            {productListing.title}
          </h3>
          <p
            class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed"
          >
            {productListing.description}
          </p>

          <OpedDeckProductListing
            rating={productListing.rating}
            price={productListing.price}
          />
        </div>
      </div>
    </div>

    <div
      class="bg-white dark:bg-neutral-900 shadow-sm p-5 border border-neutral-200 dark:border-neutral-700 rounded-2xl"
    >
      <div class="flex items-end gap-3 mb-5">
        <span
          class="font-bold text-neutral-900 dark:text-neutral-100 text-5xl leading-none"
        >
          {reviewSnapshot.average}
        </span>
        <div>
          <div class="flex gap-0.5 mb-1" aria-label="4.1 out of 5 stars">
            {
              Array.from({ length: 5 }, (_, index) => (
                <svg
                  class:list={[
                    "w-4 h-4 fill-current",
                    index < 4 ? "text-amber-400" : "text-neutral-200",
                  ]}
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))
            }
          </div>
          <p class="text-neutral-600 dark:text-neutral-400 text-sm">
            {reviewSnapshot.totalRatings} global ratings
          </p>
        </div>
      </div>

      <div class="space-y-2 mb-5">
        {
          reviewSnapshot.distribution.map((row) => (
            <div class="flex items-center gap-3">
              <span class="min-w-[44px] font-medium text-primary text-xs">
                {row.stars} star
              </span>
              <div class="flex-1 bg-neutral-100 dark:bg-neutral-800 rounded-full h-2 overflow-hidden">
                <div
                  class="bg-primary rounded-full h-full"
                  style={`width: ${row.percent}%`}
                />
              </div>
              <span class="min-w-[34px] text-neutral-600 dark:text-neutral-400 text-xs text-right">
                {row.percent}%
              </span>
            </div>
          ))
        }
      </div>

      <div class="flex flex-wrap gap-2 mb-4">
        {
          reviewSnapshot.filters.map((filter) => (
            <span
              class:list={[
                "rounded-full border px-3 py-1 text-xs font-medium",
                filter.active
                  ? "bg-primary text-white border-primary"
                  : "bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 border-neutral-200 dark:border-neutral-700",
              ]}
            >
              {filter.label} ({filter.count})
            </span>
          ))
        }
      </div>

      <p class="mb-1 text-neutral-500 text-xs">{showingText}</p>

      <div class="divide-y divide-neutral-200 dark:divide-neutral-800">
        {
          fiveStarExamples.map((review) => (
            <article class="py-3">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <div
                  class="flex gap-0.5"
                  aria-label={`${review.stars} out of 5 stars`}
                >
                  {Array.from({ length: 5 }, (_, index) => (
                    <svg
                      class:list={[
                        "w-3.5 h-3.5 fill-current",
                        index < review.stars
                          ? "text-amber-400"
                          : "text-neutral-200",
                      ]}
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="font-semibold text-neutral-900 dark:text-neutral-100 text-xs">
                  {review.stars.toFixed(1)} out of 5 stars
                </span>
                <span class="bg-primary/5 px-2 py-0.5 border border-primary/30 rounded-full text-[11px] text-primary">
                  {review.source}
                </span>
                {review.verified && (
                  <span class="px-2 py-0.5 border border-primary/30 rounded-full text-[11px] text-primary">
                    Verified Purchase
                  </span>
                )}
              </div>
              {review.hasText && review.title && (
                <p class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">
                  {review.title}
                </p>
              )}
              {review.hasText && review.body && (
                <p class="mt-1 text-neutral-700 dark:text-neutral-300 text-xs line-clamp-2 leading-relaxed">
                  {review.body}
                </p>
              )}
              <p
                class:list={[
                  "text-neutral-500 text-xs",
                  review.hasText && "mt-2",
                ]}
              >
                <span class="font-medium text-neutral-900 dark:text-neutral-100">
                  {review.name}
                </span>{" "}
                {review.meta}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</div>
