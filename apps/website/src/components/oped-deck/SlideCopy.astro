---
interface Props {
  title?: string;
  headline?: string;
  narrative?: string;
  bullets?: string[];
  class?: string;
}

const {
  title,
  headline,
  narrative,
  bullets = [],
  class: className = "",
} = Astro.props;
---

<div class={className}>
  {
    title && (
      <p class="mb-1 font-medium text-primary text-xs uppercase tracking-widest">
        {title}
      </p>
    )
  }
  {
    headline && (
      <h2 class="mb-3 font-semibold text-neutral-900 dark:text-neutral-100 text-2xl md:text-3xl leading-tight">
        {headline}
      </h2>
    )
  }
  {
    narrative && (
      <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
        {narrative}
      </p>
    )
  }
  {
    bullets.length > 0 && (
      <ul class="space-y-2.5 mt-4">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 text-sm">
            <span class="mt-0.5 font-bold text-primary shrink-0">•</span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    )
  }
</div>
