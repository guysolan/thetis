---
import AspenPromedDeckSlides from "@/components/oped-deck/AspenPromedDeckSlides.astro";
import OpedDeckLayout from "@/layouts/OpedDeckLayout.astro";
import {
  ASPEN_PROMED_DECK_BASE_PATH,
  ASPEN_PROMED_DECK_SLIDE_COUNT,
} from "@/features/oped-deck/aspenPromedDeckPitchContent";

const rawPage = Number.parseInt(Astro.params.page ?? "1", 10);

if (!Number.isFinite(rawPage) || rawPage < 1) {
  return Astro.redirect(`${ASPEN_PROMED_DECK_BASE_PATH}/1`, 301);
}

if (rawPage > ASPEN_PROMED_DECK_SLIDE_COUNT) {
  return Astro.redirect(
    `${ASPEN_PROMED_DECK_BASE_PATH}/${ASPEN_PROMED_DECK_SLIDE_COUNT}`,
    301,
  );
}

const initialPage = rawPage;
---

<OpedDeckLayout
  title="Achilles Recovery - Aspen / Promedics x Thetis"
  description="Confidential partnership overview for Aspen / Promedics and Thetis Medical."
  initialPage={initialPage}
  slideCount={ASPEN_PROMED_DECK_SLIDE_COUNT}
  basePath={ASPEN_PROMED_DECK_BASE_PATH}
  partnerName="Aspen / Promedics"
>
  <AspenPromedDeckSlides initialPage={initialPage} />
</OpedDeckLayout>
