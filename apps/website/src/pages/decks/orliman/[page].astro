---
import OpedDeckLayout from "@/layouts/OpedDeckLayout.astro";
import OrlimanDeckSlides from "@/components/oped-deck/OrlimanDeckSlides.astro";
import {
  ORLIMAN_DECK_BASE_PATH,
  ORLIMAN_DECK_SLIDE_COUNT,
} from "@/features/oped-deck/orlimanDeckPitchContent";

const rawPage = Number.parseInt(Astro.params.page ?? "1", 10);

if (!Number.isFinite(rawPage) || rawPage < 1) {
  return Astro.redirect(`${ORLIMAN_DECK_BASE_PATH}/1`, 301);
}

if (rawPage > ORLIMAN_DECK_SLIDE_COUNT) {
  return Astro.redirect(
    `${ORLIMAN_DECK_BASE_PATH}/${ORLIMAN_DECK_SLIDE_COUNT}`,
    301,
  );
}

const initialPage = rawPage;
---

<OpedDeckLayout
  title="Achilles Recovery - Orliman x Thetis"
  description="Confidential regional partnership overview for Orliman and Thetis Medical."
  initialPage={initialPage}
  slideCount={ORLIMAN_DECK_SLIDE_COUNT}
  basePath={ORLIMAN_DECK_BASE_PATH}
  partnerName="Orliman"
>
  <OrlimanDeckSlides initialPage={initialPage} />
</OpedDeckLayout>
