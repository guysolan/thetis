---
import Layout from "@/layouts/Layout.astro";
import ColorGradient from "@/components/ColorGradient.astro";
import ShopIndexHero from "@/components/shop/ShopIndexHero.astro";
import ShopFromThetisSection from "@/components/shop/ShopFromThetisSection.astro";
import ShopRecommendedByCondition from "@/components/shop/ShopRecommendedByCondition.astro";
import type { Lang } from "@/config/languages";

const lang: Lang = "it";
---

<Layout
  title="Shop — prodotti per il recupero"
  description="Tutore notturno Thetis più equipaggiamento curato per ogni condizione — stivali, plantari e partner."
  {lang}
>
  <ColorGradient>
    <main class="pb-16 md:pb-24">
      <ShopIndexHero {lang} />
      <ShopFromThetisSection {lang} />
      <ShopRecommendedByCondition {lang} />
    </main>
  </ColorGradient>
</Layout>
