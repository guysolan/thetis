---
import Layout from "@/layouts/Layout.astro";
import ColorGradient from "@/components/ColorGradient.astro";
import HighlightedWord from "@/components/HighlightedWord";
import SplintCustomerSteps from "@/components/splint-customer/SplintCustomerSteps.astro";
import LocationPrice from "@/components/splint-customer/LocationPrice";
import { Banknote } from "lucide-react";
import { CashbackClaimForm } from "@/components/CashbackClaimForm";
---

<Layout
    title="Claim Your Cashback | Thetis Medical"
    description="Claim your £10 / $15 cashback for your approved video review. Enter your details and receive payment via PayPal or bank transfer."
    image="https://thetismedical.com/images/night-splint.png"
    lang="en"
>
    <main>
        <ColorGradient>
            <div class="mx-auto px-4 py-10 md:py-12 max-w-3xl text-center">
                <SplintCustomerSteps currentStep={5} />
                <div
                    class="inline-flex items-center gap-2 bg-primary/10 dark:bg-primary/20 mb-3 px-3 py-1.5 rounded-full font-semibold text-primary text-sm"
                >
                    <Banknote className="w-4 h-4" />
                    Claim Your Reward
                </div>
                <h1
                    class="mb-3 font-bold text-neutral-900 dark:text-neutral-100 text-2xl md:text-3xl"
                >
                    Claim Your <HighlightedWord>Cashback</HighlightedWord>
                </h1>
                <p class="text-neutral-600 dark:text-neutral-400 text-sm">
                    Claim your cashback for doctor/physio sign-up and/or your
                    approved video review. Select what applies below — <LocationPrice gbp={40} usd={50} client:load /> for doctor
                    sign-up, <LocationPrice gbp={10} usd={15} client:load /> for video review (both = <LocationPrice gbp={50} usd={65} client:load />).
                    Payment via PayPal or bank transfer.
                </p>
            </div>
        </ColorGradient>

        <section class="pt-2 pb-8 md:pb-10">
            <div class="mx-auto px-4 max-w-2xl">
                <div
                    class="bg-white dark:bg-neutral-800 shadow-lg p-6 border-2 border-primary/30 dark:border-primary/50 rounded-xl"
                >
                    <CashbackClaimForm client:load />
                </div>

                <div
                    class="bg-neutral-50 dark:bg-neutral-900 mt-8 p-6 rounded-xl"
                >
                    <h3
                        class="mb-4 font-semibold text-neutral-900 dark:text-neutral-100 text-lg"
                    >
                        Payment Information
                    </h3>
                    <ul
                        class="space-y-2 text-neutral-600 dark:text-neutral-400 text-sm"
                    >
                        <li>
                            • Doctor/physio sign-up: <strong><LocationPrice gbp={40} usd={50} client:load /></strong>
                            · Video review: <strong><LocationPrice gbp={10} usd={15} client:load /></strong>
                            · Both: <strong><LocationPrice gbp={50} usd={65} client:load /></strong>
                        </li>
                        <li>• Payment methods: PayPal or Bank Transfer</li>
                        <li>
                            • Processing time: 7-10 business days after claim
                        </li>
                        <li>
                            • You'll receive a confirmation email once payment
                            is sent
                        </li>
                    </ul>
                </div>
            </div>
        </section>
    </main>
</Layout>
