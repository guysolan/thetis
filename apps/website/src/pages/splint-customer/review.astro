---
import Layout from "@/layouts/Layout.astro";
import ColorGradient from "@/components/ColorGradient.astro";
import HighlightedWord from "@/components/HighlightedWord";
import SplintCustomerSteps from "@/components/splint-customer/SplintCustomerSteps.astro";
import LocationPrice from "@/components/splint-customer/LocationPrice";
import WhatHappensNextAccordion from "@/components/splint-customer/WhatHappensNextAccordion";
import { Check, Banknote } from "lucide-react";
import { VideoReviewForm } from "@/components/VideoReviewForm";
---

<Layout
    title="Submit Video Review - Earn £10/$15 Cashback | Thetis Medical"
    description="Upload your video or photo review of our night splint and earn £10 / $15 cashback if approved. Help others while earning back!"
    image="https://thetismedical.com/images/night-splint.png"
    lang="en"
>
    <main>
        <ColorGradient>
            <div class="mx-auto px-4 py-10 md:py-12 max-w-3xl text-center">
                <SplintCustomerSteps currentStep={4} />
                <div
                    class="inline-flex items-center gap-2 bg-primary/10 dark:bg-primary/20 mb-3 px-3 py-1.5 rounded-full font-semibold text-primary text-sm"
                >
                    <Banknote className="w-4 h-4" />
                    Earn <LocationPrice gbp={10} usd={15} client:load /> Cashback
                </div>
                <h1
                    class="mb-3 font-bold text-neutral-900 dark:text-neutral-100 text-2xl md:text-3xl"
                >
                    Submit Your <HighlightedWord>Review</HighlightedWord>
                </h1>
                <p class="text-neutral-600 dark:text-neutral-400 text-sm">
                    Share your experience with our night splint and help others
                    on their recovery journey. If your review is approved,
                    you'll receive <strong><LocationPrice gbp={10} usd={15} client:load /> cashback</strong>.
                </p>
            </div>
        </ColorGradient>

        <!-- Review Guidelines -->
        <section class="pt-2 pb-8 md:pb-10">
            <div class="mx-auto px-4 max-w-2xl">
                <div
                    class="bg-primary/10 dark:bg-primary/20 mb-8 p-6 border border-primary/20 dark:border-primary/30 rounded-xl"
                >
                    <h2
                        class="mb-4 font-bold text-neutral-900 dark:text-neutral-100 text-xl"
                    >
                        Review Guidelines
                    </h2>
                    <ul
                        class="space-y-3 text-neutral-700 dark:text-neutral-300"
                    >
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                <strong>To receive cashback:</strong> We need a video (or photos) with your review. You can submit a star rating and text first and add a video later.
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                <strong>Video:</strong> At least 30 seconds long
                                showing your experience
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                <strong>Photos:</strong> Clear images of you using
                                the splint (alternative to video)
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                Share honest feedback about your experience with
                                the splint
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                Show how you use the splint (for sleeping,
                                resting, etc.)
                            </span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="mt-0.5 w-5 h-5 text-primary shrink-0"
                            />
                            <span>
                                Keep it respectful and appropriate for all
                                audiences
                            </span>
                        </li>
                    </ul>
                </div>

                <!-- Upload Form -->
                <div
                    class="bg-white dark:bg-neutral-800 shadow-lg p-8 border border-neutral-200 dark:border-neutral-700 rounded-xl"
                >
                    <VideoReviewForm client:load />
                </div>

                <!-- What Happens Next -->
                <WhatHappensNextAccordion variant="review" client:load />

                <!-- Already submitted? -->
                <div class="mt-8 text-center">
                    <p
                        class="mb-3 text-neutral-600 dark:text-neutral-400 text-sm"
                    >
                        Already submitted and approved?
                    </p>
                    <a
                        href="/splint-customer/claim-cashback"
                        class="inline-flex items-center gap-2 font-medium text-primary hover:text-primary/80"
                    >
                        <Banknote className="w-4 h-4" />
                        Claim Your Cashback →
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
