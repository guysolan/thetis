const t = content[lang];

const otherConditions = conditions.filter((c) => c.id !== "achilles-rupture");

// Get localized product/splint URLs
const splintUrl =
    lang === "en"
        ? "/achilles-rupture-splint"
        : lang === "de"
          ? "/de/achillessehnenriss-schiene"
          : lang === "fr"
            ? "/fr/attelle-rupture-tendon-achille"
            : lang === "es"
              ? "/es/bota-ortopedica-tendon-aquiles"
              : "/it/tutore-rottura-tendine-achille";

const reviewsUrl =
    lang === "en"
        ? "/reviews"
        : lang === "de"
          ? "/de/bewertungen"
          : lang === "fr"
            ? "/fr/avis"
            : lang === "es"
              ? "/es/resenas"
              : "/it/recensioni";
---

<ThetisSchema slot="head" />

<Layout
    title={t.meta.title}
    description={t.meta.description}
    image="https://thetismedical.com/images/night-splint.png"
    lang={lang}
>
    <main class="space-y-16">
        <!-- Hero Section -->
        <section
            class="bg-gradient-to-b from-primary/10 to-white py-16 md:py-24"
        >
            <div class="mx-auto px-4 max-w-7xl">
                <div class="flex lg:flex-row flex-col items-center gap-12">
                    <div class="flex-1 lg:text-left text-center">
                        <!-- Trust Badge -->
                        <div
                            class="inline-flex items-center gap-2 bg-primary/10 mb-4 px-4 py-2 rounded-full"
                        >
                            <span class="font-bold text-primary text-lg">✓</span
                            >
                            <p
                                class="font-semibold text-primary text-sm uppercase tracking-wide"
                            >
                                {t.hero.trustBadge}
                            </p>
                        </div>

                        <h1
                            class="mb-4 font-bold text-neutral-900 text-4xl md:text-6xl leading-tight"
                        >
                            {t.hero.title}
                            <span class="text-primary"
                                >{t.hero.titleHighlight}</span
                            >
                        </h1>
                        <p
                            class="mx-auto lg:mx-0 mb-2 max-w-2xl text-neutral-600 text-lg md:text-xl leading-relaxed"
                        >
                            {t.hero.subtitle}
                            <strong class="text-neutral-900">
                                {t.hero.subtitleBold}</strong
                            >
                            {t.hero.subtitleEnd}
                        </p>
                        <p
                            class="mx-auto lg:mx-0 mb-8 max-w-2xl text-neutral-500 text-base"
                        >
                            {t.hero.courseLine}
                        </p>

                        <!-- Primary CTAs -->
                        <div
                            class="flex sm:flex-row flex-col justify-center lg:justify-start gap-4 mb-6"
                        >
                            <a
                                href={splintUrl}
                                class={cn(
                                    buttonVariants({
                                        size: "lg",
                                        variant: "default",
                                    }),
                                    "w-full sm:w-auto text-lg font-bold shadow-lg hover:shadow-xl transition-all",
                                )}
                            >
                                {t.hero.shopSplint}
                            </a>
                            <a
                                href="/course"
                                class={cn(
                                    buttonVariants({
                                        size: "lg",
                                        variant: "outline",
                                    }),
                                    "w-full sm:w-auto text-lg font-semibold",
                                )}
                            >
                                {t.hero.shopCourses}
                            </a>
                        </div>

                        <!-- Trust Signals -->
                        <div
                            class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-2 mb-4 text-neutral-600 text-sm"
                        >
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium"
                                    >{t.hero.freeShipping}</span
                                >
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium"
                                    >{t.hero.moneyBack}</span
                                >
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium"
                                    >{t.hero.surgeonApproved}</span
                                >
                            </div>
                        </div>

                        <!-- Social Proof -->
                        <div
                            class="flex md:flex-row flex-col justify-center lg:justify-start items-center gap-3 mb-6 text-neutral-500 text-sm"
                        >
                            <div class="flex -space-x-2">
                                <AstroImage
                                    src={Review1Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                                <AstroImage
                                    src={Review2Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                                <AstroImage
                                    src={Review3Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                            </div>
                            <span
                                class="font-semibold text-neutral-900 md:text-left text-center"
                            >
                                {t.hero.socialProof}
                            </span>
                        </div>
                    </div>
                    <div class="flex-shrink-0 w-full lg:w-1/2">
                        <div class="relative">
                            <Image
                                src={NightSplintImage}
                                alt="Thetis Medical Achilles Rupture Night Splint"
                                class="shadow-2xl rounded-xl w-full"
                            />
                            <!-- Floating Trust Badge -->
                            <div
                                class="-right-4 -bottom-4 absolute bg-white shadow-lg p-4 border-2 border-primary/20 rounded-lg"
                            >
                                <p class="font-bold text-primary text-sm">
                                    {t.hero.zeroReruptures}
                                </p>
                                <p class="text-neutral-600 text-xs">
                                    {t.hero.inPatients}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Other conditions (guide hubs) -->
        <section class="bg-white py-8 border-neutral-100 border-b">
            <div class="mx-auto px-4 max-w-7xl text-center">
                <p
                    class="mb-4 font-medium text-neutral-500 text-sm uppercase tracking-wide"
                >
                    {t.weAlsoCover.title}
                </p>
                <div class="flex flex-wrap justify-center gap-x-8 gap-y-3">
                    {
                        otherConditions.map((c) => (
                            <a
                                href={c.learnPath}
                                class="font-semibold text-neutral-800 hover:text-primary text-base transition-colors"
                            >
                                {c.label}
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Patient Reviews -->
        <section
            class="bg-gradient-to-b from-white to-neutral-50 py-16 md:py-24"
        >
            <div class="mx-auto px-4 max-w-7xl">
                <div class="mb-8 text-center">
                    <h2
                        class="mb-4 font-bold text-neutral-900 text-3xl md:text-4xl"
                    >
                        {t.reviews.title}
                    </h2>
                    <p class="mx-auto max-w-2xl text-neutral-600 text-lg">
                        {t.reviews.subtitle}
                    </p>
                </div>
                <EnhancedReviewCarousel client:load />
                <div class="mt-8 text-center">
                    <a
                        href={reviewsUrl}
                        class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 px-6 py-3 rounded-lg font-semibold text-white transition-colors"
                    >
                        {t.reviews.viewAll}
                        <span class="text-xl">→</span>
                    </a>
                </div>
                <div class="mt-12">
                    <ExperienceIfForYourself lang={lang} />
                </div>
            </div>
        </section>

        <!-- Problem Identification -->
        <section class="py-16 md:py-20">
            <div class="mx-auto px-4 max-w-5xl">
                <div class="mb-12 text-center">
                    <p
                        class="mb-4 font-medium text-primary text-sm uppercase tracking-widest"
                    >
                        {t.problem.tagline}
                    </p>
                    <h2
                        class="mb-4 font-bold text-neutral-900 text-3xl md:text-4xl"
                    >
                        {t.problem.title}
                    </h2>
                    <p class="mx-auto max-w-2xl text-neutral-600 text-lg">
                        {t.problem.subtitle}
                    </p>
                </div>
                <div class="gap-6 grid md:grid-cols-2">
                    <a
                        href="#cant-sleep"
                        class="group bg-white hover:bg-primary/5 p-8 border-2 border-primary/30 hover:border-primary rounded-xl text-left transition-all"
                    >
                        <div class="flex items-start gap-4">
                            <div
                                class="flex flex-shrink-0 justify-center items-center bg-primary/10 group-hover:bg-primary/20 rounded-lg w-12 h-12 transition-colors"
                            >
                                <span class="text-2xl">😴</span>
                            </div>
                            <div class="flex-1">
                                <h3
                                    class="mb-2 font-bold text-neutral-900 text-xl"
                                >
                                    {t.problem.cantSleep.title}
                                </h3>
                                <p class="mb-4 text-neutral-600">
                                    {t.problem.cantSleep.description}
                                </p>
                                <span
                                    class="font-semibold text-primary group-hover:underline"
                                >
                                    {t.problem.cantSleep.cta}
                                </span>
                            </div>
                        </div>
                    </a>
                    <a
                        href="#confused"
                        class="group bg-white hover:bg-primary/5 p-8 border-2 border-primary/30 hover:border-primary rounded-xl text-left transition-all"
                    >
                        <div class="flex items-start gap-4">
                            <div
                                class="flex flex-shrink-0 justify-center items-center bg-primary/10 group-hover:bg-primary/20 rounded-lg w-12 h-12 transition-colors"
                            >
                                <span class="text-2xl">🤔</span>
                            </div>
                            <div class="flex-1">
                                <h3
                                    class="mb-2 font-bold text-neutral-900 text-xl"
                                >
                                    {t.problem.confused.title}
                                </h3>
                                <p class="mb-4 text-neutral-600">
                                    {t.problem.confused.description}
                                </p>
                                <span
                                    class="font-semibold text-primary group-hover:underline"
                                >
                                    {t.problem.confused.cta}
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
