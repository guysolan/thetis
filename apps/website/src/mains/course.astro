---
import CourseShell from "@/layouts/CourseShell.astro";
import type { Lang } from "@/config/languages";
import { getAchillesRuptureCourseCopy } from "@/content/course/achilles-rupture/translations";
import { buildAchillesRuptureLessonPreviews } from "@/content/course/achilles-rupture/build-lesson-previews";

interface Props {
    lang?: Lang;
}

const { lang = "en" } = Astro.props;

const t = getAchillesRuptureCourseCopy(lang);
const lessonPreviews = buildAchillesRuptureLessonPreviews(t);
---

<CourseShell lang={lang} t={t} lessonPreviews={lessonPreviews} />
