---
import FAQsLayout from "../../layouts/FAQsLayout.astro";
import PlantarFasciitisOverviewSection from "@/sections/FAQs/plantar-fasciitis-overview.astro";
import type { Lang } from "../../config/languages";

const { lang = "en" } = Astro.props as { lang: Lang };

const content: Record<Lang, { title: string; description: string }> = {
    en: {
        title: "Plantar fasciitis — overview",
        description:
            "What plantar fasciitis is, whether heel pain gets better, first-step pain, how long recovery takes, and where to start.",
    },
    de: {
        title: "Plantarfasziitis — Überblick",
        description:
            "Was Plantarfasziitis ist, ob Fersenschmerz besser wird, Morgenschmerz, Dauer der Genesung und wo Sie anfangen.",
    },
    fr: {
        title: "Fasciite plantaire — aperçu",
        description:
            "Qu’est-ce que la fasciite plantaire, si la douleur s’améliore, douleur matinale, durée et par où commencer.",
    },
    es: {
        title: "Fascitis plantar — resumen",
        description:
            "Qué es la fascitis plantar, si el dolor mejora, dolor matutino, duración y por dónde empezar.",
    },
    it: {
        title: "Fascite plantare — panoramica",
        description:
            "Cos’è la fascite plantare, se il dolore migliora, dolore mattutino, durata e da dove iniziare.",
    },
};

const currentContent = content[lang];
---

<FAQsLayout
    title={currentContent.title}
    description={currentContent.description}
    lang={lang}
    illustration="plantar-fasciitis"
>
    <PlantarFasciitisOverviewSection lang={lang} />
</FAQsLayout>
