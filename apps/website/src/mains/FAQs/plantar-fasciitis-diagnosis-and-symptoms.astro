---
import FAQsLayout from "@/layouts/FAQsLayout.astro";
import type { Lang } from "@/config/languages";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const title = "Plantar fasciitis — diagnosis & symptoms";
const description =
  "Coming soon — Signs and assessment of plantar fasciitis.";
---

<FAQsLayout title={title} description={description} lang={lang} illustration="plantar-fasciitis">
  <section class="mx-auto px-4 py-8 max-w-3xl prose prose-neutral">
    <p>Coming soon.</p>
  </section>
</FAQsLayout>
