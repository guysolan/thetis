---
import FAQsLayout from "@/layouts/FAQsLayout.astro";
import type { Lang } from "@/config/languages";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const title = "Insertional tendonitis — treatment & footwear";
const description =
  "Coming soon — Heel lifts, footwear, and symptom relief.";
---

<FAQsLayout title={title} description={description} lang={lang}>
  <section class="mx-auto px-4 py-8 max-w-3xl prose prose-neutral">
    <p>Coming soon.</p>
  </section>
</FAQsLayout>
