---
import type { Lang } from "@/config/languages";
import Layout from "@/layouts/Layout.astro";
import ColorGradient from "@/components/ColorGradient.astro";
import HighlightedWord from "@/components/HighlightedWord";
import SplintCustomerChoiceCards from "@/components/splint-customer/SplintCustomerChoiceCards.astro";
import { getSplintCustomerPath } from "@/lib/splint-customer-paths";
import { getSplintCustomerCopy } from "@/features/splint-customer/splintCustomerCopy";
import { Gift } from "lucide-react";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;
const t = getSplintCustomerCopy(lang);
const discountCode = "SPLINT20";
const claimHref = getSplintCustomerPath("claim-cashback", lang);
const shareHref = getSplintCustomerPath("share-doctor", lang);
---

<Layout
  title={t.meta.index.title}
  description={t.meta.index.description}
  image="https://thetismedical.com/images/night-splint.png"
  lang={lang}
>
  <main>
    <ColorGradient>
      <div class="mx-auto px-4 py-10 md:py-14 max-w-4xl text-center">
        <div
          class="inline-flex items-center gap-2 bg-primary/10 dark:bg-primary/20 mb-4 px-3 py-1.5 rounded-full font-semibold text-primary text-sm"
        >
          <Gift className="w-4 h-4" />
          {t.index.badge}
        </div>
        <h1
          class="mb-3 font-bold text-neutral-900 dark:text-neutral-100 text-2xl md:text-4xl text-balance"
        >
          {t.index.title}{" "}
          <HighlightedWord>{t.index.titleHighlight}</HighlightedWord>
        </h1>
        <p
          class="mx-auto mb-8 max-w-2xl text-neutral-600 dark:text-neutral-400 text-base md:text-lg leading-relaxed"
        >
          {t.index.intro}
        </p>

        <SplintCustomerChoiceCards lang={lang} discountCode={discountCode} />
      </div>
    </ColorGradient>

    <section class="mx-auto px-4 py-8 max-w-2xl text-center">
      <p class="text-neutral-600 dark:text-neutral-400 text-sm">
        {t.index.claimPrompt}
        <a
          href={claimHref}
          class="font-medium text-primary hover:text-primary/80"
        >
          {t.index.claimLink}
        </a>
      </p>
      <p class="mt-3 text-neutral-500 text-xs">
        <a href={shareHref} class="hover:text-primary hover:underline">
          {t.index.shareLink}
        </a>
      </p>
    </section>
  </main>

  <script define:vars={{ discountCode }}>
    if (typeof window !== "undefined") {
      sessionStorage.setItem("splintDiscountCode", discountCode);
    }
  </script>
</Layout>
