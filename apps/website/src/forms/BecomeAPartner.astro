const currentContent = content[lang];
---

<FormWrap formId="xwppakoz">
    <div class="space-y-8 w-full">
        <h2
            class="font-semibold text-neutral-950 text-2xl md:text-3xl leading-[105%]"
        >
            {currentContent.title}
        </h2>
        <p class="text-gray-800 text-lg leading-relaxed">
            {currentContent.description}
        </p>

        <div class="space-y-6">
            <div class="gap-6 grid md:grid-cols-2">
                <div class="form-group">
                    <Label labelFor="name"
                        >{currentContent.contactNameLabel}</Label
                    >
                    <Input name="name" type="text" required={true} />
                </div>

                <div class="form-group">
                    <Label labelFor="email"
                        >{currentContent.businessEmailLabel}</Label
                    >
                    <Input name="email" type="email" required={true} />
                </div>
            </div>

            <div class="form-group">
                <Label labelFor="company"
                    >{currentContent.companyNameLabel}</Label
                >
                <Input name="company" type="text" required={true} />
            </div>

            <fieldset
                id="partner-territories"
                class="form-group border-0 p-0"
                data-territory-error={currentContent.territoryRequiredError}
            >
                <legend class="mb-1 font-semibold text-base text-neutral-700">
                    {currentContent.territoryLabel}
                </legend>
                <p class="mb-3 text-neutral-500 text-sm">
                    {currentContent.territoryHint}
                </p>
                <div class="gap-3 grid sm:grid-cols-2">
                    {
                        currentContent.territoryOptions.map((option) => (
                            <Checkbox
                                name="territory"
                                value={option.value}
                                label={option.label}
                            />
                        ))
                    }
                </div>
                <p
                    id="territory-error"
                    class="hidden mt-2 text-red-600 text-sm"
                    role="alert"
                >
                </p>
            </fieldset>

            <div class="form-group">
                <Label labelFor="partnerType"
                    >{currentContent.partnershipTypeLabel}</Label
                >
                <select
                    required
                    id="partnerType"
                    name="partnerType"
                    class={`${inputStyle} w-full rounded-lg bg-white/90`}
                >
                    <option value=""
                        >{currentContent.emptyPartnershipOption}</option
                    >
                    <option value="distributor"
                        >{currentContent.distributorOption}</option
                    >
                    <option value="license"
                        >{currentContent.licenseOption}</option
                    >
                    <option value="clinic">{currentContent.clinicOption}</option
                    >
                    <option value="clinician"
                        >{currentContent.clinicianOption}</option
                    >
                    <option value="other">{currentContent.otherOption}</option>
                </select>
            </div>

            <div class="form-group">
                <Label labelFor="message"
                    >{currentContent.additionalInfoLabel}</Label
                >
                <TextArea
                    name="message"
                    rows={4}
                    maxlength={1000}
                    placeholder={currentContent.additionalInfoHint}
                />
            </div>

            <OptOut />

            <button
                type="submit"
                class="bg-primary hover:bg-primary/90 hover:shadow-md px-8 py-4 rounded-lg w-full md:w-auto font-medium text-white transition-all"
            >
                {currentContent.submitButton}
            </button>
        </div>
    </div>
</FormWrap>

<script>
    const fieldset = document.getElementById("partner-territories");
    const form = fieldset?.closest("form");
    const errorEl = document.getElementById("territory-error");

    form?.addEventListener("submit", (event) => {
        const checked = form.querySelectorAll<HTMLInputElement>(
            'input[name="territory"]:checked',
        );
        if (checked.length > 0) {
            errorEl?.classList.add("hidden");
            return;
        }
        event.preventDefault();
        if (errorEl && fieldset) {
            errorEl.textContent =
                fieldset.dataset.territoryError ??
                "Please select at least one territory.";
            errorEl.classList.remove("hidden");
        }
        fieldset?.scrollIntoView({ behavior: "smooth", block: "center" });
    });

    form
        ?.querySelectorAll('input[name="territory"]')
        .forEach((input) => {
            input.addEventListener("change", () => {
                const anyChecked = form.querySelector(
                    'input[name="territory"]:checked',
                );
                if (anyChecked) errorEl?.classList.add("hidden");
            });
        });
</script>
