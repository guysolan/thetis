---
// Import the global.css file here so that it is included on
// import '../styles/global.css'
import "@thetis/ui/globals.css";
import Analytics from "@vercel/analytics/astro";

export interface Props {
    title: string;
    description: string;
    image?: string;
    lang?: string;
    alternateLanguages?: Array<{
        lang: string;
        url: string;
    }>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
    title,
    description,
    image = "/images/night_splint_bed_top_square.jpg",
    lang = "en",
    alternateLanguages = [],
} = Astro.props;

const siteOrigin =
    Astro.site?.href?.replace(/\/$/, "") ?? "https://thetismedical.com";
const absoluteImageUrl = image.startsWith("http")
    ? image
    : `${siteOrigin}${image.startsWith("/") ? image : `/${image}`}`;
---

<!-- Global Metadata -->
<meta charset="UTF-8" />
<meta
    name="viewport"
    content="width=device-width, initial-scale=1, minimum-scale=1"
/>

<!-- Language and Localization -->
<meta name="language" content={lang} />
<meta property="og:locale" content={lang} />

<!-- Hreflang tags for multilingual SEO -->
{
    alternateLanguages.map(({ lang: altLang, url }) => (
        <link rel="alternate" hreflang={altLang} href={url} />
    ))
}
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<!-- NPM Generated Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Enable pin website icon on Windows 8 Modern UI -->
<meta name="msapplication-TileColor" content="#5a9784" />
<meta name="theme-color" content="#5a9784" />

<!-- Favicon -->
<link
    rel="apple-touch-icon"
    sizes="180x180"
    href="/favicon/apple-touch-icon.png"
/>
<link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href="/favicon/favicon-32x32.png"
/>
<link
    rel="icon"
    type="image/png"
    sizes="16x16"
    href="/favicon//favicon-16x16.png"
/>
<link rel="manifest" href="./favicon/site.webmanifest" />
<link rel="mask-icon" href="./favicon/safari-pinned-tab.svg" color="#5bbad5" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Facebook Pixel -->
<meta
    name="facebook-domain-verification"
    content="bcoih90qhlv8c8286vpm16xqtcu84e"
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImageUrl} />
<meta property="og:image:alt" content={title} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@ThetisMedical" />
<meta name="twitter:creator" content="@ThetisMedical" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImageUrl} />
<meta name="twitter:image:alt" content={title} />

<Analytics />
