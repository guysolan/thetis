---
import Layout from "@/layouts/Layout.astro";
import ColorGradientInOut from "@/components/ColorGradientInOut.astro";
import HighlightedWord from "@/components/HighlightedWord";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import CourseBuyButton from "@/components/CourseBuyButton";
import { SHOPIFY_COURSE_PRODUCTS } from "@/lib/shopify-course-price";
import InfiniteReviews from "@/components/reviews/InfiniteReviews.astro";
import { Image as AstroImage } from "astro:assets";
import Review1Image from "@/assets/review-1.png";
import Review2Image from "@/assets/review-2.png";
import Review3Image from "@/assets/review-3.png";
import StickyAddToCart from "@/components/StickyAddToCart";
import SubscribeBlock from "@/components/CTA/SubscribeBlock.astro";
import ClinicianCourseAccess from "@/forms/ClinicianCourseAccess.astro";
import type { Lang } from "@/config/languages";
import type { AchillesRuptureCourseCopy } from "@/content/course/achilles-rupture/translations";
import type { LessonPreviewPhase } from "@/content/course/achilles-rupture/build-lesson-previews";
import {
    Check,
    Star,
    Stethoscope,
    Users,
    BookOpen,
    GraduationCap,
    ExternalLink,
    X,
} from "lucide-react";

export interface Props {
    lang?: Lang;
    t: AchillesRuptureCourseCopy;
    lessonPreviews: LessonPreviewPhase[];
}

const { lang = "en", t, lessonPreviews } = Astro.props;
---


<Layout
    title={t.meta.title}
    description={t.meta.description}
    image="https://thetismedical.com/images/night-splint.png"
    lang={lang}
>
    <main class="space-y-16">
        <!-- Hero Section - Matching Home Page Style -->
        <section
            class="bg-gradient-to-b from-primary/10 to-white py-16 md:py-24"
        >
            <div class="mx-auto px-4 max-w-7xl">
                <div class="flex lg:flex-row flex-col items-center gap-12">
                    <div class="flex-1 lg:text-left text-center">
                        <!-- Social Proof Badge -->
                        <div class="mb-6">
                            <div
                                class="inline-flex items-center gap-2 bg-primary/10 mb-3 px-4 py-2 rounded-full"
                            >
                                <Users className="w-4 h-4 text-primary" />
                                <span
                                    class="font-semibold text-primary text-sm uppercase tracking-wider"
                                    >{t.hero.badge}</span
                                >
                            </div>
                        </div>
                        <h1
                            class="mb-4 font-bold text-neutral-900 text-4xl md:text-6xl leading-tight"
                        >
                            {t.hero.title}
                            <span class="text-primary"
                                >{t.hero.titleHighlight}</span
                            >
                            {t.hero.titleEnd}
                        </h1>
                        <p
                            class="mx-auto lg:mx-0 mb-4 max-w-2xl text-neutral-600 text-lg md:text-xl leading-relaxed"
                            set:html={t.hero.subtitle}
                        />
                        <p
                            class="mx-auto lg:mx-0 mb-8 max-w-2xl text-neutral-500 text-base"
                            set:html={t.hero.subtitlePlain}
                        />

                        <!-- Primary CTA -->
                        <div
                            class="flex sm:flex-row flex-col justify-center lg:justify-start gap-4 mb-6"
                        >
                            <CourseBuyButton
                                productId={SHOPIFY_COURSE_PRODUCTS.ESSENTIALS_COURSE}
                                variant="default"
                                className="shadow-lg hover:shadow-xl w-full sm:w-auto font-bold text-lg transition-all"
                                client:load
                            >
                                {t.hero.cta}
                            </CourseBuyButton>
                        </div>

                        <!-- Trust Signals -->
                        <div
                            class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-2 mb-4 text-neutral-600 text-sm"
                        >
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium">{t.hero.trust1}</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium">{t.hero.trust2}</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="font-bold text-primary text-lg"
                                    >✓</span
                                >
                                <span class="font-medium">{t.hero.trust3}</span>
                            </div>
                        </div>

                        <!-- Social Proof -->
                        <div
                            class="flex justify-center lg:justify-start items-center gap-3 mb-6 text-neutral-500 text-sm"
                        >
                            <div class="flex -space-x-2">
                                <AstroImage
                                    src={Review1Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                                <AstroImage
                                    src={Review2Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                                <AstroImage
                                    src={Review3Image}
                                    alt="Patient review"
                                    class="border-2 border-white rounded-full w-10 h-10 object-cover"
                                    width={40}
                                    height={40}
                                />
                            </div>
                            <span class="font-semibold text-neutral-900"
                                >{t.hero.socialProof}</span
                            >
                        </div>
                    </div>
                    <div class="flex-shrink-0 w-full lg:w-1/2">
                        <div class="relative">
                            <img
                                src="/images/achilles-rope-ends-pointed-down.png"
                                alt="Achilles tendon healing positions diagram"
                                class="shadow-2xl rounded-xl w-full"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Common Mistakes Section -->
        <section class="bg-red-50 dark:bg-red-950/20 py-12 md:py-16">
            <div class="mx-auto px-4 max-w-4xl">
                <div class="mb-8 text-center">
                    <h2
                        class="mb-4 font-bold text-neutral-900 dark:text-neutral-100 text-2xl md:text-3xl"
                    >
                        {t.mistakes.title}
                    </h2>
                    <p class="text-neutral-600 dark:text-neutral-400">
                        {t.mistakes.subtitle}
                    </p>
                </div>
                <div class="gap-4 grid md:grid-cols-2 mb-8">
                    <div
                        class="bg-white dark:bg-neutral-800 p-5 border border-red-200 dark:border-red-900/50 rounded-lg"
                    >
                        <div class="flex items-start gap-3">
                            <X
                                className="mt-0.5 w-5 h-5 text-red-500 shrink-0"
                            />
                            <div>
                                <p
                                    class="font-semibold text-neutral-900 dark:text-neutral-100"
                                >
                                    {t.mistakes.mistake1Title}
                                </p>
                                <p
                                    class="text-neutral-600 dark:text-neutral-400 text-sm"
                                >
                                    {t.mistakes.mistake1Desc}
                                </p>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-neutral-800 p-5 border border-red-200 dark:border-red-900/50 rounded-lg"
                    >
                        <div class="flex items-start gap-3">
                            <X
                                className="mt-0.5 w-5 h-5 text-red-500 shrink-0"
                            />
                            <div>
                                <p
                                    class="font-semibold text-neutral-900 dark:text-neutral-100"
                                >
                                    {t.mistakes.mistake2Title}
                                </p>
                                <p
                                    class="text-neutral-600 dark:text-neutral-400 text-sm"
                                >
                                    {t.mistakes.mistake2Desc}
                                </p>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-neutral-800 p-5 border border-red-200 dark:border-red-900/50 rounded-lg"
                    >
                        <div class="flex items-start gap-3">
                            <X
                                className="mt-0.5 w-5 h-5 text-red-500 shrink-0"
                            />
                            <div>
                                <p
                                    class="font-semibold text-neutral-900 dark:text-neutral-100"
                                >
                                    {t.mistakes.mistake3Title}
                                </p>
                                <p
                                    class="text-neutral-600 dark:text-neutral-400 text-sm"
                                >
                                    {t.mistakes.mistake3Desc}
                                </p>
                            </div>
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-neutral-800 p-5 border border-red-200 dark:border-red-900/50 rounded-lg"
                    >
                        <div class="flex items-start gap-3">
                            <X
                                className="mt-0.5 w-5 h-5 text-red-500 shrink-0"
                            />
                            <div>
                                <p
                                    class="font-semibold text-neutral-900 dark:text-neutral-100"
                                >
                                    {t.mistakes.mistake4Title}
                                </p>
                                <p
                                    class="text-neutral-600 dark:text-neutral-400 text-sm"
                                >
                                    {t.mistakes.mistake4Desc}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <p
                    class="font-medium text-neutral-700 dark:text-neutral-300 text-center"
                >
                    {t.mistakes.footer}
                </p>
            </div>
        </section>

        <!-- What to Expect: Recovery Timeline -->
        <section class="py-16 md:py-24">
            <div class="mx-auto px-4 max-w-5xl">
                <div class="mb-12 text-center">
                    <h2
                        class="mb-4 font-bold text-neutral-900 dark:text-neutral-100 text-3xl"
                    >
                        {t.timeline.title}
                    </h2>
                    <p
                        class="mx-auto max-w-2xl text-neutral-600 dark:text-neutral-400"
                    >
                        {t.timeline.subtitle}
                    </p>
                </div>
                <div class="relative">
                    <!-- Timeline line -->
                    <div
                        class="hidden md:block top-0 bottom-0 left-1/2 absolute bg-primary/20 w-0.5 -translate-x-1/2"
                    >
                    </div>

                    <div class="space-y-6 md:space-y-12">
                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2 md:text-right">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Week 0-1"
                                                : lang === "de"
                                                  ? "Woche 0-1"
                                                  : lang === "fr"
                                                    ? "Semaine 0-1"
                                                    : lang === "es"
                                                      ? "Semana 0-1"
                                                      : "Settimana 0-1"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.week01.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.week01.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.week01.teaser}
                                    </p>
                                </div>
                            </div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2"></div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2"></div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Weeks 2-6"
                                                : lang === "de"
                                                  ? "Wochen 2-6"
                                                  : lang === "fr"
                                                    ? "Semaines 2-6"
                                                    : lang === "es"
                                                      ? "Semanas 2-6"
                                                      : "Settimane 2-6"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.week26.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.week26.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.week26.teaser}
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2 md:text-right">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Weeks 6-12"
                                                : lang === "de"
                                                  ? "Wochen 6-12"
                                                  : lang === "fr"
                                                    ? "Semaines 6-12"
                                                    : lang === "es"
                                                      ? "Semanas 6-12"
                                                      : "Settimane 6-12"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.week612.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.week612.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.week612.teaser}
                                    </p>
                                </div>
                            </div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2"></div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2"></div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Months 3-4"
                                                : lang === "de"
                                                  ? "Monate 3-4"
                                                  : lang === "fr"
                                                    ? "Mois 3-4"
                                                    : lang === "es"
                                                      ? "Meses 3-4"
                                                      : "Mesi 3-4"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.month34.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.month34.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.month34.teaser}
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2 md:text-right">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Months 4-6"
                                                : lang === "de"
                                                  ? "Monate 4-6"
                                                  : lang === "fr"
                                                    ? "Mois 4-6"
                                                    : lang === "es"
                                                      ? "Meses 4-6"
                                                      : "Mesi 4-6"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.month46.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.month46.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.month46.teaser}
                                    </p>
                                </div>
                            </div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2"></div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2"></div>
                            <div
                                class="hidden md:block left-1/2 absolute -translate-x-1/2"
                            >
                                <div
                                    class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                >
                                </div>
                            </div>
                            <div class="w-full md:w-1/2">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Months 6-9"
                                                : lang === "de"
                                                  ? "Monate 6-9"
                                                  : lang === "fr"
                                                    ? "Mois 6-9"
                                                    : lang === "es"
                                                      ? "Meses 6-9"
                                                      : "Mesi 6-9"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.month69.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.month69.desc}
                                    </p>
                                    <p
                                        class="mt-2 font-medium text-primary text-sm italic"
                                    >
                                        {t.timeline.month69.teaser}
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="relative flex items-center gap-8">
                            <div class="w-full md:w-1/2 md:text-right">
                                <div
                                    class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                >
                                    <div
                                        class="mb-2 font-bold text-primary text-2xl"
                                    >
                                        {
                                            lang === "en"
                                                ? "Months 9-12"
                                                : lang === "de"
                                                  ? "Monate 9-12"
                                                  : lang === "fr"
                                                    ? "Mois 9-12"
                                                    : lang === "es"
                                                      ? "Meses 9-12"
                                                      : "Mesi 9-12"
                                        }
                                    </div>
                                    <h3 class="mb-2 font-semibold text-xl">
                                        {t.timeline.month912.title}
                                    </h3>
                                    <p
                                        class="text-neutral-600 dark:text-neutral-400"
                                    >
                                        {t.timeline.month912.desc}
                                    </p>
                                </div>
                                <div
                                    class="hidden md:block left-1/2 absolute -translate-x-1/2"
                                >
                                    <div
                                        class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                    >
                                    </div>
                                </div>
                                <div class="w-full md:w-1/2"></div>
                            </div>

                            <div class="relative flex items-center gap-8">
                                <div class="w-full md:w-1/2"></div>
                                <div
                                    class="hidden md:block left-1/2 absolute -translate-x-1/2"
                                >
                                    <div
                                        class="bg-primary border-4 border-white dark:border-neutral-900 rounded-full w-4 h-4"
                                    >
                                    </div>
                                </div>
                                <div class="w-full md:w-1/2">
                                    <div
                                        class="bg-white md:bg-transparent dark:bg-neutral-800 dark:md:bg-transparent p-4 md:p-0 border border-neutral-200 md:border-0 dark:border-neutral-700 rounded-lg md:rounded-none"
                                    >
                                        <div
                                            class="mb-2 font-bold text-primary text-2xl"
                                        >
                                            {
                                                lang === "en"
                                                    ? "12+ Months"
                                                    : lang === "de"
                                                      ? "12+ Monate"
                                                      : lang === "fr"
                                                        ? "12+ Mois"
                                                        : lang === "es"
                                                          ? "12+ Meses"
                                                          : "12+ Mesi"
                                            }
                                        </div>
                                        <h3 class="mb-2 font-semibold text-xl">
                                            {t.timeline.month12plus.title}
                                        </h3>
                                        <p
                                            class="text-neutral-600 dark:text-neutral-400"
                                        >
                                            {t.timeline.month12plus.desc}
                                        </p>
