                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Social Proof Banner -->
            <section class="bg-primary/5 dark:bg-primary/10 mt-24 py-8">
                <div class="mx-auto px-4 max-w-6xl">
                    <div
                        class="flex flex-wrap justify-center items-center gap-6 md:gap-8 text-center"
                    >
                        <div class="flex items-center gap-2">
                            <Stethoscope className="w-5 h-5 text-primary" />
                            <span
                                class="font-semibold text-neutral-900 dark:text-neutral-100"
                            >
                                {t.socialBanner.specialists}
                            </span>
                        </div>
                        <div class="hidden md:block bg-primary/20 w-px h-8">
                        </div>
                        <div class="flex items-center gap-2">
                            <GraduationCap className="w-5 h-5 text-primary" />
                            <span
                                class="font-semibold text-neutral-900 dark:text-neutral-100"
                            >
                                {t.socialBanner.research}
                            </span>
                        </div>
                        <div class="hidden md:block bg-primary/20 w-px h-8">
                        </div>
                        <div class="flex items-center gap-2">
