---
import { DesktopNav } from "./DesktopNav.tsx";
import { MobileNav } from "./MobileNav.tsx";
import Thetis from "./Thetis.tsx";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { CurrencySwitcher } from "../components/CurrencySwitcher";
import type { Lang } from "@/config/languages";
import { CartIcon } from "../components/cart/CartIcon";

export interface Props {
    lang: Lang;
}

const { lang = "en" } = Astro.props as Props;
const currentPath = Astro.url.pathname;
---

<header
    class="top-0 z-[40] fixed flex bg-background m-auto my-auto px-2 lg:px-8 py-4 border-gray-300 border-b w-screen overflow-visible item-center"
>
    <div
        class="hidden lg:grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-3 w-full text-base"
    >
        <div class="flex justify-start items-center min-w-0">
            <Thetis lang={lang} />
        </div>
        <div
            class="flex justify-center items-stretch min-w-0 overflow-visible"
        >
            <DesktopNav client:load lang={lang} />
        </div>
        <div class="flex justify-end items-center gap-x-1.5 min-w-0">
            <div class="shrink-0">
                <LanguageSwitcher />
            </div>
            <div class="shrink-0">
                <CurrencySwitcher client:load className="w-[124px]" />
            </div>
            <div class="shrink-0">
                <CartIcon client:load className="justify-center px-2" />
            </div>
        </div>
    </div>

    <div class="lg:hidden flex justify-between items-center w-full">
        <Thetis lang={lang} />
        <div class="flex items-center gap-x-2">
            <CartIcon client:load />
            <MobileNav client:load lang={lang} currentPath={currentPath} />
        </div>
    </div>
</header>
