---
import type { Lang } from "@/config/languages";

export interface Props {
    title: string;
    description: string;
    lang: Lang;
    alternateLanguages?: Array<{
        lang: string;
        url: string;
    }>;
}

const {
    title,
    description,
    lang = "en",
    alternateLanguages = [],
} = Astro.props;

import Layout from "./Layout.astro";
import OtherArticles from "@/components/OtherArticles.astro";
import Article from "@/components/research/Article.astro";
import ShareControls from "@/components/research/ShareControls";
import StickyAddToCart from "@/components/StickyAddToCart.tsx";
---

<Layout
    title={title}
    description={description}
    image="https://thetismedical.com/images/achilles-drawing-image.png"
    lang={lang}
    alternateLanguages={alternateLanguages}
>
    <main class="relative flex flex-col gap-4 print:w-full print:max-w-none">
        <Article title={title} />
        <slot />
        <OtherArticles lang={lang} />
        <ShareControls client:load />
    </main>
    <StickyAddToCart
        variant="splint"
        lang={lang}
        splintHref={lang === "en" ? "/achilles-rupture-splint" : lang === "de" ? "/de/achillessehnenriss-schiene" : lang === "fr" ? "/fr/attelle-rupture-tendon-achille" : lang === "es" ? "/es/bota-ortopedica-tendon-aquiles" : "/it/tutore-rottura-tendine-achille"}
        client:load
    />
</Layout>

<style>
    html {
        scroll-behavior: smooth;
    }

    @media print {
        html {
            scroll-behavior: auto;
        }
    }
</style>

<style is:global>
    .faq.slide {
        width: min(80vw, 1200px);
        margin: 0 auto;
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 2rem;
        padding: 2rem 0;
    }

    .faq.slide .questions {
        width: 25%;
        min-width: 200px;
        position: sticky;
        top: 5rem;
    }

    .faq.slide .questions h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #171717;
    }

    .faq.slide .questions h3 {
        font-size: 1rem;
        font-weight: 400;
        margin: 1.5rem 0;
        color: #404040;
        transition: color 0.15s;
    }

    .faq.slide .questions a {
        text-decoration: none;
    }

    .faq.slide .questions a:hover h3 {
        color: hsl(161, 60%, 40%);
    }

    .faq.slide .questions ul {
        padding-left: 1.25rem;
        list-style: none;
    }

    .faq.slide .answers {
        width: 75%;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .faq.slide .answers h2 {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem 0;
        padding: 0;
        color: #171717;
    }

    .faq.slide .answers p {
        font-weight: 400;
        font-size: 1.125rem;
        line-height: 1.7;
        text-align: left;
        color: #404040;
        margin-bottom: 0.5rem;
    }

    .faq.slide .answers a {
        color: hsl(161, 60%, 40%);
        font-weight: 500;
        text-decoration: underline;
    }

    .faq.slide .answers ul {
        padding-left: 1.5rem;
        margin: 0.5rem 0 1rem 0;
    }

    .faq.slide .answers li {
        font-size: 1.125rem;
        line-height: 1.7;
        color: #404040;
        margin-bottom: 1rem;
    }

    .faq.slide .answers b {
        color: #171717;
        font-weight: 600;
    }

    @media (max-width: 768px) {
        .faq.slide {
            flex-direction: column;
            width: 90vw;
        }

        .faq.slide .questions {
            width: 100%;
            position: static;
        }

        .faq.slide .answers {
            width: 100%;
        }
    }

    @media print {
        .faq.slide {
            width: 95%;
        }
    }
</style>
