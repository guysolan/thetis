---
/**
 * US-only banner on the splint page: simple hook → link to the guided flow.
 */
import { ShieldCheck } from "lucide-react";
---

<section class="bg-primary/5 py-6 md:py-8 border-y border-primary/20">
    <div class="mx-auto px-4 max-w-4xl">
        <a
            href="/achilles-rupture-splint/get-covered"
            class="flex items-center gap-4 md:gap-6 group"
        >
            <div class="flex justify-center items-center bg-primary/10 group-hover:bg-primary/20 rounded-full w-12 h-12 md:w-14 md:h-14 shrink-0 transition-colors">
                <ShieldCheck className="w-6 h-6 md:w-7 md:h-7 text-primary" />
            </div>
            <div class="flex-1 min-w-0">
                <p class="font-bold text-neutral-900 text-lg md:text-xl">
                    🇺🇸 In the US? Get this splint covered.
                </p>
                <p class="text-neutral-600 text-sm md:text-base">
                    Use HSA/FSA funds, or file for insurance reimbursement. We'll guide you through it.
                </p>
            </div>
            <svg class="w-5 h-5 text-primary shrink-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </a>
    </div>
</section>
