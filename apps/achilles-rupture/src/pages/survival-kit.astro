---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import {
    type AchillesProduct,
    SURVIVAL_KIT_PRODUCTS,
    defaultProductCta,
    isOffSiteUrl,
    resolveProductPrice,
    resolveProductUrl,
} from "@thetis/catalogue";

const survivalKitProducts = SURVIVAL_KIT_PRODUCTS;

function priceUS(item: AchillesProduct) {
    return resolveProductPrice(item, "us") ?? "";
}
function priceGB(item: AchillesProduct) {
    return resolveProductPrice(item, "gb") ?? "";
}
function urlUS(item: AchillesProduct) {
    return resolveProductUrl(item, "us") ?? "";
}
function urlGB(item: AchillesProduct) {
    return resolveProductUrl(item, "gb") ?? "";
}
function ctaUS(item: AchillesProduct) {
    return defaultProductCta(urlUS(item));
}
function offSite(item: AchillesProduct) {
    return isOffSiteUrl(urlUS(item));
}

// Filter products by priority
const essentialItems = survivalKitProducts.filter(item => item.priority === "essential");
const BOOT_PRODUCT_IDS = new Set([
    "aircast-airselect-boot",
    "vacoped-achilles-boot",
]);
const essentialBootItems = essentialItems.filter((item) =>
    BOOT_PRODUCT_IDS.has(item.id),
);
const essentialNonBootItems = essentialItems.filter(
    (item) => !BOOT_PRODUCT_IDS.has(item.id),
);
const recommendedItems = survivalKitProducts.filter(item => item.priority === "recommended");
const comfortItems = survivalKitProducts.filter(item => item.priority === "comfort");
const optionalItems = survivalKitProducts.filter(item => item.priority === "optional");

const pageTitle = "Achilles Rupture Survival Kit | Essential Products for Recovery";
const pageDescription = "The life changing products you need for Achilles rupture recovery. Simple, clear recommendations for what works.";

// Enhanced Schema.org structured data
const schemaData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "ItemList",
            name: "Achilles Rupture Survival Kit",
            description: pageDescription,
            numberOfItems: survivalKitProducts.length,
            itemListElement: survivalKitProducts.map((item, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "Product",
                    name: item.name,
                    description: item.keyBenefit,
                    category: item.category,
                    brand: {
                        "@type": "Brand",
                        name: item.name.includes("Thetis") ? "Thetis Medical" : "Various"
                    },
                    offers: {
                        "@type": "Offer",
                        price:
                            String(resolveProductPrice(item, "us") ?? "").match(
                                /[\d.]+/,
                            )?.[0] ?? "0",
                        priceCurrency: "USD",
                        availability: "https://schema.org/InStock",
                        url: resolveProductUrl(item, "us"),
                    },
                    image: item.imagePath,
                    additionalProperty: item.features?.map(feature => ({
                        "@type": "PropertyValue",
                        name: "Feature",
                        value: feature
                    }))
                }
            }))
        },
        {
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "What are the most essential items for Achilles rupture recovery?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "You need one walking boot (either an Aircast-style CAM walker or a VACOped-style hinged boot—not both) plus protection at night, such as the Thetis night splint if your team approves. The boot protects your healing tendon during the day; night protection helps sleep and hygiene."
                    }
                },
                {
                    "@type": "Question",
                    name: "How much should I expect to spend on recovery equipment?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Essential items cost $240-420 (£190-335), recommended items add $125-160 (£98-127), and comfort items add $85-145 (£67-116). Total investment for everything you need is typically $450-725 (£355-575)."
                    }
                }
            ]
        }
    ]
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={pageTitle} description={pageDescription} />
        <meta property="og:type" content="article" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <link
            rel="canonical"
            href={new URL(Astro.url.pathname, Astro.site).toString()}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData)}
        />
        <style>
            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 500;
                text-decoration: none;
                border-radius: 0.375rem;
                transition: all 0.2s;
                cursor: pointer;
                padding: 0.5rem 1rem;
                font-size: 0.875rem;
            }

            .btn-primary {
                background-color: #1a1a1a;
                color: white;
                border: 1px solid #1a1a1a;
            }

            .btn-primary:hover {
                background-color: #333;
                border-color: #333;
            }

            .btn-secondary {
                background-color: #e5e7eb;
                color: #1a1a1a;
                border: 1px solid #e5e7eb;
            }

            .btn-secondary:hover {
                background-color: #d1d5db;
                border-color: #d1d5db;
            }

            .product-card {
                background: white;
                border-radius: 12px;
                box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
                transition: transform 0.2s, box-shadow 0.2s;
                overflow: hidden;
            }

            .product-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            }

            .priority-badge {
                display: inline-block;
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 0.875rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .essential-badge {
                background-color: #fee2e2;
                color: #dc2626;
            }

            .recommended-badge {
                background-color: #dbeafe;
                color: #2563eb;
            }

            .comfort-badge {
                background-color: #fef3c7;
                color: #d97706;
            }

            .optional-badge {
                background-color: #f3e8ff;
                color: #7c3aed;
            }

            .product-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 1.5rem;
            }

            @media (max-width: 768px) {
                .product-grid {
                    grid-template-columns: 1fr;
                }
            }

            .boot-choice-grid {
                display: grid;
                grid-template-columns: 1fr;
                gap: 1.5rem;
                align-items: stretch;
            }

            @media (min-width: 768px) {
                .boot-choice-grid {
                    grid-template-columns: 1fr 1fr;
                }
            }

            .boot-card .boot-card-body {
                display: flex;
                flex-direction: column;
                flex: 1;
            }
        </style>
    </head>
