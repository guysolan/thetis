# Create at https://dub.co/docs/api-reference/authentication#api-keys
DUB_API_KEY=dub_xxxxxxxx

# Optional: short-link hostname you configured in Dub (defaults to workspace primary / dub.sh)
# DUB_DOMAIN=dub.sh

# Free plans have a low monthly link cap; rows already in dub-link-map.generated.ts are
# skipped by default (pass --force to re-hit the API for those keys).
