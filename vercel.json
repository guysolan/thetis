{
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": false,
      "preview": false
    }
  },
  "installCommand": "bun install --ignore-scripts",
  "buildCommand": "turbo build --filter=@thetis/website",
  "outputDirectory": "apps/website/dist",
  "build": {
    "env": {
      "ENABLE_TURBO_INSTALL": "0"
    }
  }
}
