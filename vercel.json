{
  "git": {
    "deploymentEnabled": {
      "main": false,
      "master": true,
      "dev": false,
      "preview": false
    }
  },
  "installCommand": "pnpm install --filter @thetis/website... --ignore-scripts",
  "buildCommand": "pnpm --filter @thetis/website build",
  "outputDirectory": "apps/website/.vercel/output",
  "build": {
    "env": {
      "ENABLE_TURBO_INSTALL": "0"
    }
  }
}
